---
// blog.astro - Blog Page for ActionPath Africa
import Layout from "../layouts/Layout.astro";
import { getCollection } from 'astro:content';

// Fetch all blog posts from the 'blog' collection
const allPosts = await getCollection('blog');

// Sort posts by date (newest first)
const posts = allPosts.sort((a, b) => {
  return new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime();
});

// Get featured posts (those marked as featured in frontmatter)
const featuredPosts = posts.filter(post => post.data.featured === true).slice(0, 2);

// Get recent posts for the main grid (all non-featured or all if no featured)
const recentPosts = featuredPosts.length > 0 
  ? posts.filter(post => !post.data.featured).slice(0, 6)
  : posts.slice(0, 6);

// Get unique categories for filter buttons
const categories = ["All", ...new Set(posts.map(post => post.data.category).filter(Boolean))];

// Helper function to format date
const formatDate = (date) => {
  if (!date) return '';
  const d = new Date(date);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};
---

<Layout
  title="Blog | ActionPath Africa - Stories of Transformation & Impact"
  description="Read inspiring stories, insights, and lessons from our livelihood training programs across Africa. Discover how we're transforming communities through empowerment and skills development."
>

  <!-- ══════════════════════════════════════════ HERO SECTION ══════════════════════════════════════════ -->
  <section class="blog-hero">
    <div class="blog-hero-overlay"></div>
    <div class="blog-hero-content">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <i class="fas fa-chevron-right"></i>
        <span>Blog</span>
      </div>
      <div class="hero-eyebrow">
        <i class="fas fa-newspaper"></i> Stories & Insights
      </div>
      <h1>Voices of <span class="hero-accent-red">Transformation</span></h1>
      <p>Inspiring stories, practical insights, and lessons from the communities we serve across Africa.</p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ FEATURED POSTS SECTION ══════════════════════════════════════════ -->
  {featuredPosts.length > 0 && (
    <section class="featured-section">
      <div class="section-inner">
        <div class="section-header">
          <div class="section-eyebrow"><i class="fas fa-star"></i> Featured Stories</div>
          <h2>Latest <span class="accent-red">Impact Stories</span></h2>
          <div class="section-divider"></div>
          <p class="section-subtitle">Real stories of transformation from the communities we serve</p>
        </div>

        <div class="featured-grid">
          {featuredPosts.map((post) => (
            <a href={`/blog/${post.id}`} class="featured-card" key={post.id}>
              <div class="featured-image">
                <img src={post.data.image || '/blog-placeholder.webp'} alt={post.data.title} loading="lazy" />
                <div class="featured-category">
                  <i class={post.data.categoryIcon || 'fas fa-tag'}></i> {post.data.category || 'Story'}
                </div>
              </div>
              <div class="featured-content">
                <div class="post-meta">
                  <span><i class="fas fa-calendar-alt"></i> {formatDate(post.data.pubDate)}</span>
                  <span><i class="fas fa-clock"></i> {post.data.readTime || '5 min read'}</span>
                </div>
                <h3 class="featured-title">{post.data.title}</h3>
                <p class="featured-excerpt">{post.data.description || post.data.excerpt}</p>
                <div class="featured-author">
                  {post.data.authorImage && (
                    <img src={post.data.authorImage} alt={post.data.author} class="author-avatar" />
                  )}
                  <span class="author-name">{post.data.author || 'ActionPath Editorial'}</span>
                </div>
                <span class="read-more">Read Full Story <i class="fas fa-arrow-right"></i></span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ══════════════════════════════════════════ ALL POSTS SECTION ══════════════════════════════════════════ -->
  <section class="all-posts-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-eyebrow"><i class="fas fa-blog"></i> Latest Articles</div>
        <h2>All <span class="accent-red">Blog Posts</span></h2>
        <div class="section-divider"></div>
        <p class="section-subtitle">Insights, lessons, and stories from our work across Africa</p>
      </div>

      <!-- Category Filters -->
      {categories.length > 1 && (
        <div class="filter-buttons" id="filterButtons">
          {categories.map(category => (
            <button class="filter-btn" data-category={category} key={category}>
              {category}
            </button>
          ))}
        </div>
      )}

      <!-- Blog Grid -->
      <div class="blog-grid" id="blogGrid">
        {posts.map((post, idx) => (
          <div class="blog-card" data-category={post.data.category || 'Uncategorized'} key={post.id}>
            <div class="blog-image">
              <img src={post.data.image || '/blog-placeholder.webp'} alt={post.data.title} loading="lazy" />
              <div class="blog-category-badge">
                <i class={post.data.categoryIcon || 'fas fa-tag'}></i> {post.data.category || 'Story'}
              </div>
            </div>
            <div class="blog-content">
              <div class="post-meta">
                <span><i class="fas fa-calendar-alt"></i> {formatDate(post.data.pubDate)}</span>
                <span><i class="fas fa-clock"></i> {post.data.readTime || '5 min read'}</span>
              </div>
              <h3 class="blog-title">{post.data.title}</h3>
              <p class="blog-excerpt">{post.data.description || post.data.excerpt}</p>
              <div class="blog-footer">
                <div class="blog-author">
                  {post.data.authorImage && (
                    <img src={post.data.authorImage} alt={post.data.author} class="author-avatar-small" />
                  )}
                  <span>{post.data.author || 'ActionPath Editorial'}</span>
                </div>
                <a href={`/blog/${post.id}`} class="read-link">Read <i class="fas fa-arrow-right"></i></a>
              </div>
            </div>
          </div>
        ))}
      </div>

      {posts.length === 0 && (
        <div class="no-posts">
          <i class="fas fa-newspaper"></i>
          <h3>No posts yet</h3>
          <p>Check back soon for stories and insights from our programs.</p>
        </div>
      )}
    </div>
  </section>

  <!-- ══════════════════════════════════════════ NEWSLETTER SECTION ══════════════════════════════════════════ -->
  <section class="newsletter-section">
    <div class="newsletter-container">
      <div class="newsletter-content">
        <div class="newsletter-icon">
          <i class="fas fa-envelope-open-text"></i>
        </div>
        <h2>Subscribe to Our <span class="accent-green">Newsletter</span></h2>
        <p>Get impact stories, program updates, and opportunities to get involved — delivered straight to your inbox.</p>
        <form class="newsletter-form" action="/newsletter" method="POST">
          <input type="email" name="email" placeholder="Your email address" required class="newsletter-input" />
          <button type="submit" class="btn-newsletter">
            <i class="fas fa-paper-plane"></i> Subscribe
          </button>
        </form>
        <p class="newsletter-note"><i class="fas fa-shield-alt"></i> No spam. Unsubscribe anytime.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ CTA SECTION ══════════════════════════════════════════ -->
  <section class="blog-cta-section">
    <div class="cta-container">
      <div class="cta-content">
        <div class="cta-eyebrow">Want to Share Your Story?</div>
        <h2>Have a <span class="cta-highlight">Transformation Story</span> to Tell?</h2>
        <p>If you've been impacted by our programs and want to share your journey, we'd love to hear from you.</p>
        <div class="cta-buttons">
          <a href="/contact" class="btn-cta-primary">
            <i class="fas fa-envelope"></i> Share Your Story
          </a>
          <a href="/contact" class="btn-cta-secondary">
            <i class="fas fa-handshake"></i> Partner With Us
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style is:global>
  :root {
    --red: #c0392b;
    --red-dark: #a93226;
    --red-soft: rgba(192, 57, 43, 0.1);
    --green: #27ee31;
    --green-lt: #27f731;
    --charcoal: #1e293b;
    --gray-dk: #334155;
    --gray-md: #5a6e8a;
    --gray-sf: #f5f7fa;
    --border: #e2e8f0;
    --white: #ffffff;
    --shadow-sm: 0 4px 12px rgba(0, 0, 0, 0.05);
    --shadow-md: 0 8px 24px rgba(0, 0, 0, 0.08);
    --shadow-lg: 0 20px 35px rgba(0, 0, 0, 0.12);
    --shadow-xl: 0 30px 50px rgba(0, 0, 0, 0.15);
  }

  /* ══════════════════════════════════════════ HERO SECTION ══════════════════════════════════════════ */
  .blog-hero {
    position: relative;
    min-height: 50vh;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, var(--charcoal) 0%, #0f172a 100%);
    overflow: hidden;
  }
  
  .blog-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url('/hero-training-3.webp');
    background-size: cover;
    background-position: center;
    opacity: 0.15;
    filter: blur(2px);
  }
  
  .blog-hero-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 40%, rgba(30,41,59,0.6) 0%, var(--charcoal) 100%);
  }
  
  .blog-hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    padding: 4rem 5%;
    margin-left: 5%;
  }
  
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }
  
  .breadcrumb a {
    color: rgba(255, 255, 255, 0.65);
    transition: color 0.2s;
    text-decoration: none;
  }
  
  .breadcrumb a:hover {
    color: var(--green-lt);
  }
  
  .breadcrumb i {
    font-size: 0.6rem;
  }
  
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(39, 238, 49, 0.15);
    backdrop-filter: blur(8px);
    color: var(--green);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border-radius: 40px;
    margin-bottom: 1.25rem;
    border: 1px solid rgba(39, 238, 49, 0.3);
  }
  
  .blog-hero-content h1 {
    font-family: "Outfit", sans-serif;
    font-size: 3rem;
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: white;
    margin-bottom: 1.25rem;
  }
  
  .hero-accent-red {
    color: var(--red);
  }
  
  .hero-accent-green {
    color: var(--green);
  }
  
  .blog-hero-content p {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.7;
    max-width: 580px;
  }

  /* ══════════════════════════════════════════ FEATURED SECTION ══════════════════════════════════════════ */
  .featured-section {
    padding: 5rem 0;
    background: linear-gradient(135deg, #fff 0%, var(--gray-sf) 100%);
  }
  
  .section-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--red-soft);
    color: var(--red);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.35rem 1rem;
    border-radius: 40px;
    margin-bottom: 0.85rem;
  }
  
  .section-header h2 {
    font-family: "Outfit", sans-serif;
    font-size: 2.2rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    margin-bottom: 0.5rem;
    color: var(--charcoal);
  }
  
  .accent-red {
    color: var(--red);
  }
  
  .section-divider {
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, var(--red), var(--green));
    margin: 0.75rem auto 1.25rem;
    border-radius: 3px;
  }
  
  .section-subtitle {
    font-size: 0.95rem;
    color: var(--gray-md);
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.6;
  }
  
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  
  .featured-card {
    background: var(--white);
    border-radius: 28px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
  }
  
  .featured-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-xl);
    border-color: var(--green);
  }
  
  .featured-image {
    position: relative;
    height: 280px;
    overflow: hidden;
  }
  
  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1);
  }
  
  .featured-card:hover .featured-image img {
    transform: scale(1.08);
  }
  
  .featured-category {
    position: absolute;
    top: 16px;
    left: 16px;
    background: var(--red);
    color: white;
    padding: 0.3rem 0.9rem;
    border-radius: 30px;
    font-size: 0.7rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 6px;
    z-index: 1;
  }
  
  .featured-content {
    padding: 1.75rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  
  .post-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.7rem;
    color: var(--gray-md);
    margin-bottom: 0.75rem;
  }
  
  .post-meta i {
    margin-right: 4px;
  }
  
  .featured-title {
    font-family: "Outfit", sans-serif;
    font-size: 1.3rem;
    font-weight: 800;
    line-height: 1.3;
    margin-bottom: 0.75rem;
    color: var(--charcoal);
  }
  
  .featured-excerpt {
    font-size: 0.85rem;
    color: var(--gray-md);
    line-height: 1.6;
    margin-bottom: 1.25rem;
    flex: 1;
  }
  
  .featured-author {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1rem;
  }
  
  .author-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
  }
  
  .author-name {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--gray-dk);
  }
  
  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--red);
    font-weight: 700;
    font-size: 0.85rem;
    transition: gap 0.2s ease;
  }
  
  .featured-card:hover .read-more {
    gap: 12px;
  }

  /* ══════════════════════════════════════════ ALL POSTS SECTION ══════════════════════════════════════════ */
  .all-posts-section {
    padding: 5rem 0;
    background: var(--white);
  }
  
  /* Filter Buttons */
  .filter-buttons {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }
  
  .filter-btn {
    padding: 0.5rem 1.25rem;
    border: 2px solid var(--border);
    background: var(--white);
    border-radius: 40px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--gray-dk);
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .filter-btn:hover {
    border-color: var(--green);
    color: var(--green);
    transform: translateY(-2px);
  }
  
  .filter-btn.active {
    background: var(--red);
    border-color: var(--red);
    color: white;
  }
  
  /* Blog Grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  
  .blog-card {
    background: var(--white);
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeUp 0.6s ease forwards;
  }
  
  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
  
  .blog-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: var(--red);
  }
  
  .blog-image {
    position: relative;
    height: 200px;
    overflow: hidden;
  }
  
  .blog-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1);
  }
  
  .blog-card:hover .blog-image img {
    transform: scale(1.08);
  }
  
  .blog-category-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--green);
    color: var(--charcoal);
    padding: 0.25rem 0.7rem;
    border-radius: 20px;
    font-size: 0.65rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  
  .blog-content {
    padding: 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  
  .blog-title {
    font-family: "Outfit", sans-serif;
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.4;
    margin-bottom: 0.5rem;
    color: var(--charcoal);
  }
  
  .blog-excerpt {
    font-size: 0.8rem;
    color: var(--gray-md);
    line-height: 1.6;
    margin-bottom: 1rem;
    flex: 1;
  }
  
  .blog-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }
  
  .blog-author {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.7rem;
    color: var(--gray-md);
  }
  
  .author-avatar-small {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    object-fit: cover;
  }
  
  .read-link {
    color: var(--red);
    font-weight: 700;
    font-size: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: gap 0.2s;
    text-decoration: none;
  }
  
  .read-link:hover {
    gap: 8px;
  }
  
  .no-posts {
    text-align: center;
    padding: 4rem;
    background: var(--gray-sf);
    border-radius: 24px;
  }
  
  .no-posts i {
    font-size: 3rem;
    color: var(--gray-md);
    margin-bottom: 1rem;
  }
  
  .no-posts h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    color: var(--charcoal);
  }
  
  .no-posts p {
    color: var(--gray-md);
  }

  /* ══════════════════════════════════════════ NEWSLETTER SECTION ══════════════════════════════════════════ */
  .newsletter-section {
    background: linear-gradient(135deg, var(--charcoal) 0%, #2d3748 100%);
    padding: 4rem 2rem;
    text-align: center;
  }
  
  .newsletter-container {
    max-width: 600px;
    margin: 0 auto;
  }
  
  .newsletter-icon {
    font-size: 3rem;
    color: var(--green);
    margin-bottom: 1rem;
  }
  
  .newsletter-content h2 {
    font-family: "Outfit", sans-serif;
    font-size: 1.8rem;
    font-weight: 800;
    color: white;
    margin-bottom: 1rem;
  }
  
  .accent-green {
    color: var(--green);
  }
  
  .newsletter-content p {
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 1.5rem;
  }
  
  .newsletter-form {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  
  .newsletter-input {
    flex: 1;
    padding: 0.85rem 1.25rem;
    border-radius: 50px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.15);
    color: white;
    font-size: 0.9rem;
    outline: none;
    transition: all 0.3s ease;
  }
  
  .newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.6);
  }
  
  .newsletter-input:focus {
    border-color: var(--green);
    background: rgba(255, 255, 255, 0.25);
  }
  
  .btn-newsletter {
    background: linear-gradient(135deg, var(--red), var(--red-dark));
    color: white;
    padding: 0.85rem 1.75rem;
    border-radius: 50px;
    font-weight: 700;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  
  .btn-newsletter:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(192, 57, 43, 0.4);
  }
  
  .newsletter-note {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.5);
  }

  /* ══════════════════════════════════════════ CTA SECTION ══════════════════════════════════════════ */
  .blog-cta-section {
    background: linear-gradient(135deg, var(--red) 0%, var(--red-dark) 100%);
    padding: 4rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  
  .blog-cta-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 70% 30%, rgba(255,255,255,0.1), transparent);
    pointer-events: none;
  }
  
  .cta-container {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  
