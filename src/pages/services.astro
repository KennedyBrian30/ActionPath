<script>
  // Hero wipe transition
  (function() {
    const HOLD_MS = 5000;
    const WIPE_DURATION = 1200;
    function easeInOutCubic(t) { return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 4) / 2; }
    const gallery = document.getElementById("heroGallery");
    const wipe = document.getElementById("heroWipe");
    const edge = document.getElementById("heroWipeEdge");
    const slides = Array.from(gallery ? gallery.querySelectorAll(".hero-slide") : []);
    if (!slides.length || !wipe || !edge) return;
    let current = 0, animating = false;
    function scheduleNext() { setTimeout(runWipe, HOLD_MS); }
    function runWipe() {
      if (animating) return;
      animating = true;
      const outgoing = slides[current];
      const next = (current + 1) % slides.length;
      const incoming = slides[next];
      incoming.style.setProperty("--wipe-right", "100%");
      incoming.classList.add("is-incoming");
      wipe.style.transition = "none";
      wipe.style.clipPath = "inset(0 0 0 100%)";
      wipe.style.opacity = "1";
      edge.style.transition = "none";
      edge.style.left = "100%";
      edge.style.opacity = "1";
      let startTime = null;
      function step(ts) {
        if (!startTime) startTime = ts;
        const raw = Math.min((ts - startTime) / WIPE_DURATION, 1);
        const t = easeInOutCubic(raw);
        const closedPct = t * 100;
        const openLeft = 100 - closedPct;
        const edgePct = 100 - closedPct;
        wipe.style.clipPath = `inset(0 0 0 ${openLeft}%)`;
        incoming.style.setProperty("--wipe-right", `${openLeft}%`);
        edge.style.left = `calc(${edgePct}% - 2px)`;
        if (raw < 1) { requestAnimationFrame(step); }
        else {
          outgoing.classList.remove("is-active");
          incoming.classList.remove("is-incoming");
          incoming.classList.add("is-active");
          incoming.style.removeProperty("--wipe-right");
          wipe.style.transition = "opacity 0.2s";
          wipe.style.opacity = "0";
          edge.style.transition = "opacity 0.2s";
          edge.style.opacity = "0";
          setTimeout(() => { wipe.style.transition = "none"; wipe.style.clipPath = "inset(0 0 0 100%)"; edge.style.transition = "none"; }, 250);
          current = next;
          animating = false;
          scheduleNext();
        }
      }
      requestAnimationFrame(step);
    }
    slides[current].classList.add("is-active");
    scheduleNext();
  })();

  // Intersection Observer for scroll animations
  (function() {
    const animatedElements = document.querySelectorAll('.training-category-card, .consultancy-service-card, .method-card, .toolkit-card, .partner-card');
    if (animatedElements.length) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.style.animationPlayState = 'running';
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
      animatedElements.forEach(el => { 
        el.style.animationPlayState = 'paused'; 
        observer.observe(el); 
      });
    }
  })();

  // Staggered count animation for stats
  (function() {
    const statNumbers = document.querySelectorAll('.hero-stat-number, .approach-stat-number');
    if (statNumbers.length) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target;
            const text = el.innerText;
            const target = parseInt(text.replace(/[^0-9]/g, ''));
            if (!isNaN(target) && target > 0) {
              let current = 0;
              const increment = target / 50;
              const timer = setInterval(() => {
                current += increment;
                if (current >= target) {
                  el.innerText = target + (text.includes('+') ? '+' : '%');
                  clearInterval(timer);
                } else {
                  el.innerText = Math.floor(current) + (text.includes('+') ? '+' : '%');
                }
              }, 30);
            }
            observer.unobserve(el);
          }
        });
      }, { threshold: 0.5 });
      statNumbers.forEach(el => observer.observe(el));
    }
  })();
</script>