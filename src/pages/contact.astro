  }
  .response-note i { color: var(--green-dk); }

  /* social */
  .social-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: .5rem; }
  .social-list a {
    display: flex; align-items: center; gap: 10px;
    padding: .55rem .8rem; border-radius: 8px;
    text-decoration: none; font-size: .83rem; font-weight: 600;
    color: var(--ink); border: 1px solid var(--border);
    transition: background var(--transition), color var(--transition), border-color var(--transition);
  }
  .social-list a i { color: var(--clr, var(--red)); font-size: .9rem; width: 18px; text-align: center; }
  .social-list a:hover { background: var(--clr, var(--red)); color: white; border-color: transparent; }
  .social-list a:hover i { color: white; }

  /* urgent card */
  .urgent-card {
    background: linear-gradient(135deg, var(--red), var(--red-dk));
    color: white; text-align: center; border-color: transparent;
  }
  .urgent-card:hover { border-color: transparent; }
  .urgent-card i    { font-size: 1.8rem; margin-bottom: .5rem; display: block; }
  .urgent-card p    { font-size: .85rem; opacity: .85; margin: 0 0 .3rem; }
  .urgent-card a    { display: block; font-size: 1.3rem; font-weight: 900; color: white; text-decoration: none; }
  .urgent-card a:hover { text-decoration: underline; }
  .urgent-card small { font-size: .72rem; opacity: .7; margin-top: .3rem; display: block; }

  /* ── SHARED SECTION STYLES ── */
  .inner { max-width: 1400px; margin: 0 auto; padding: 0 2rem; }
  .section-head { text-align: center; margin-bottom: 2.5rem; }
  .section-head h2 {
    font-family: "Outfit", sans-serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; color: var(--ink);
    margin: .4rem 0 .2rem;
  }
  .section-head p { font-size: .9rem; color: var(--ink-60); max-width: 520px; margin: .5rem auto 0; }

  /* reasons */
  .reasons-section { padding: 5rem 0; background: var(--surface); }
  .reasons-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem; list-style: none; padding: 0; margin: 0;
  }
  .reason-card {
    background: var(--card-bg); border-radius: var(--r-md);
    padding: 2rem 1.5rem; text-align: center;
    border: 1px solid var(--border);
    transition: transform .3s, box-shadow .3s;
  }
  .reason-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-md); }
  .reason-icon {
    width: 64px; height: 64px;
    background: linear-gradient(135deg, var(--red), var(--red-dk));
    border-radius: 20px;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.1rem; color: white; font-size: 1.6rem;
  }
  .reason-card h3 { font-size: 1rem; font-weight: 700; color: var(--ink); margin-bottom: .5rem; }
  .reason-card p  { font-size: .82rem; color: var(--ink-60); line-height: 1.6; }

  /* faq */
  .faq-section { padding: 5rem 0; background: #fff; }
  .faq-list {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 1.1rem; max-width: 1000px; margin: 0 auto;
  }
  .faq-item {
    background: var(--surface); border-radius: var(--r-sm);
    border: 1px solid var(--border); overflow: hidden;
  }
  .faq-item summary {
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    padding: 1.1rem 1.25rem;
    font-weight: 700; font-size: .88rem; color: var(--ink);
    cursor: pointer; list-style: none;
    transition: background var(--transition);
  }
  .faq-item summary:hover { background: rgba(192,57,43,.05); }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary i { transition: transform .3s; flex-shrink: 0; color: var(--red); font-size: .75rem; }
  .faq-item[open] summary { background: rgba(192,57,43,.06); }
  .faq-item[open] summary i { transform: rotate(180deg); }
  .faq-body { padding: .2rem 1.25rem 1.1rem; }
  .faq-body p { font-size: .84rem; color: var(--ink-60); line-height: 1.7; margin: 0; }

  /* map */
  .map-section { padding: 3rem 0 5rem; background: var(--surface); }
  .map-wrap { position: relative; border-radius: var(--r-lg); overflow: hidden; box-shadow: var(--shadow-md); }
  .map-badge {
    position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%);
    background: rgba(30,41,59,.92); backdrop-filter: blur(6px);
    color: white; font-size: .8rem; font-weight: 600;
    padding: .6rem 1.2rem; border-radius: 30px;
    display: flex; align-items: center; gap: 8px; white-space: nowrap;
  }
  .map-badge i { color: var(--red); }

  /* cta */
  .cta-section {
    padding: 5rem 0;
    background: linear-gradient(135deg, var(--ink) 0%, #0f172a 100%);
    text-align: center;
  }
  .cta-inner { max-width: 600px; margin: 0 auto; padding: 0 2rem; }
  .cta-inner h2 {
    font-family: "Outfit", sans-serif;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 900; color: white;
    margin: .6rem 0 1rem;
  }
  .cta-inner p { font-size: .9rem; color: rgba(255,255,255,.75); line-height: 1.7; margin-bottom: 1.8rem; }
  .btn-cta {
    display: inline-flex; align-items: center; gap: 8px;
    background: linear-gradient(135deg, var(--red), var(--red-dk));
    color: white; padding: .95rem 2rem; border-radius: 50px;
    text-decoration: none; font-weight: 700; font-size: .9rem;
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .btn-cta:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(192,57,43,.45); }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .main-grid      { grid-template-columns: 1fr; }
    .reasons-grid   { grid-template-columns: repeat(2, 1fr); }
    .faq-list       { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .row-2          { grid-template-columns: 1fr; }
    .reasons-grid   { grid-template-columns: 1fr; }
    .form-card      { padding: 1.5rem; }
    .hero-inner     { padding: 3rem 1.25rem; }
  }

  /* ── REDUCED MOTION ── */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { transition: none !important; animation: none !important; }
  }
</style>

<!-- ═══════════════════════════════════════════ SCRIPT ═══════════════════════════════════════════ -->
<script define:vars={{ GOOGLE_SCRIPT_URL }}>
(function () {
  "use strict";

  // ── CONFIG ──────────────────────────────────────────────────────────────
  const SCRIPT_URL = GOOGLE_SCRIPT_URL;
  const MAX_CHARS  = 5000;

  const REASON_DESCRIPTIONS = {
    training:    "Request information about our training programmes, schedules, and fees.",
    consultancy: "Discuss your organisation's capacity building and consultancy needs.",
    partnership: "Explore collaboration, funding, and strategic partnership possibilities.",
    media:       "For media inquiries, interviews, and press coverage requests.",
    speaking:    "Invite our team to speak at your event or conference.",
    general:     "Any other questions or comments about ActionPath Africa.",
  };

  // ── DOM REFS ─────────────────────────────────────────────────────────────
  const form        = document.getElementById("contactForm");
  const submitBtn   = document.getElementById("submitBtn");
  const statusEl    = document.getElementById("formStatus");
  const charCountEl = document.getElementById("charCount");
  const tsInput     = document.getElementById("formTimestamp");
  const reasonHint  = document.getElementById("reasonHint");
  const reasonSel   = form.querySelector('[name="reason"]');

  tsInput.value = new Date().toISOString();

  // ── VALIDATION RULES ─────────────────────────────────────────────────────
  const EMAIL_RE = /^[^\s@]+@([^\s@.,]+\.)+[^\s@.,]{2,}$/;
  const PHONE_RE = /^[\+\d\s\-()\u00a0]{7,20}$/;

  const rules = {
    name:         v => !v ? "Full name is required."
                        : v.length < 2 ? "Name must be at least 2 characters."
                        : v.length > 100 ? "Name is too long (max 100 characters)."
                        : null,
    email:        v => !v ? "Email address is required."
                        : !EMAIL_RE.test(v) ? "Enter a valid email address."
                        : null,
    phone:        v => v && !PHONE_RE.test(v) ? "Enter a valid phone number." : null,
    organization: v => v && v.length > 100 ? "Organisation name is too long (max 100 characters)." : null,
    reason:       v => !v ? "Please select a reason for contacting." : null,
    message:      v => !v ? "Message is required."
                        : v.length < 20 ? "Message must be at least 20 characters."
                        : v.length > MAX_CHARS ? `Message must be under ${MAX_CHARS.toLocaleString()} characters.`
                        : null,
  };

  // ── FIELD HELPERS ─────────────────────────────────────────────────────────
  const getField = name => form.querySelector(`[data-name="${name}"]`);
  const getVal   = name => { const el = form.querySelector(`[name="${name}"]`); return el ? el.value.trim() : ""; };

  function setError(name, msg) {
    const field = getField(name);
    if (!field) return;
    const hasErr = !!msg;
    field.classList.toggle("has-error", hasErr);
    field.classList.toggle("is-valid",  !hasErr && getVal(name) !== "");
    const errEl = field.querySelector(".field-error");
    if (errEl) errEl.textContent = msg || "";
  }

  function validateField(name) {
    const err = rules[name] ? rules[name](getVal(name)) : null;
    setError(name, err);
    return !err;
  }

  // ── REAL-TIME VALIDATION ─────────────────────────────────────────────────
  ["name", "email", "phone", "organization", "reason", "message"].forEach(name => {
    const input = form.querySelector(`[name="${name}"]`);
    if (!input) return;
    const blurEvent = input.tagName === "SELECT" ? "change" : "blur";
    input.addEventListener(blurEvent, () => validateField(name));
    input.addEventListener("input", () => {
      if (getField(name)?.classList.contains("has-error")) validateField(name);
    });
  });

  // ── REASON HINT ──────────────────────────────────────────────────────────
  if (reasonSel && reasonHint) {
    reasonSel.addEventListener("change", () => {
      reasonHint.textContent = REASON_DESCRIPTIONS[reasonSel.value] || "";
    });
  }

  // ── CHARACTER COUNTER ─────────────────────────────────────────────────────
  const msgInput = form.querySelector('[name="message"]');
  if (msgInput && charCountEl) {
    const update = () => {
      const len = msgInput.value.length;
      charCountEl.textContent = `${len.toLocaleString()} / ${MAX_CHARS.toLocaleString()}`;
      charCountEl.classList.toggle("warn", len > MAX_CHARS * 0.9 && len <= MAX_CHARS);
      charCountEl.classList.toggle("over", len > MAX_CHARS);
    };
    msgInput.addEventListener("input", update);
    update();
  }

  // ── STATUS BANNER ─────────────────────────────────────────────────────────
  function showStatus(type, html) {
    statusEl.className = `status-banner ${type}`;
    statusEl.innerHTML = html;
    statusEl.hidden = false;
    statusEl.scrollIntoView({ behavior: "smooth", block: "nearest" });
  }

  // ── FULL VALIDATION ────────────────────────────────────────────────────────
  function validateAll() {
    const fields = ["name", "email", "phone", "organization", "reason", "message"];
    const results = fields.map(n => validateField(n));

    // Cross-field: phone OR organisation required
    const phone = getVal("phone");
    const org   = getVal("organization");
    if (!phone && !org) {
      setError("phone",        "Please provide a phone number or organisation name.");
      setError("organization", "Please provide a phone number or organisation name.");
      results.push(false);
    } else {
      // Clear cross-field error if already individually passing
      if (!rules.phone(phone))        setError("phone",        null);
      if (!rules.organization(org))   setError("organization", null);
    }

    return results.every(Boolean);
  }

  // ── FORM SUBMIT ────────────────────────────────────────────────────────────
  form.addEventListener("submit", async function (e) {
    e.preventDefault();
    statusEl.hidden = true;

    if (!validateAll()) {
      showStatus("error", "⚠️ Please fix the highlighted fields before sending.");
      const firstError = form.querySelector(".has-error input, .has-error select, .has-error textarea");
      firstError?.focus();
      return;
    }

    // Refresh timestamp
    tsInput.value = new Date().toISOString();

    const payload = new URLSearchParams({
      name:         getVal("name"),
      email:        getVal("email"),
      phone:        getVal("phone"),
      organization: getVal("organization"),
      reason:       getVal("reason"),
      message:      getVal("message"),
      newsletter:   form.querySelector('[name="newsletter"]')?.checked ? "subscribe" : "no",
      timestamp:    tsInput.value,
    });

    submitBtn.disabled = true;
    submitBtn.classList.add("loading");
    showStatus("sending", '<i class="fas fa-circle-notch fa-spin"></i> Sending your message…');

    try {
      // POST to Apps Script. Use no-cors to avoid CORS preflight issues
      // with the redirect that Apps Script /exec performs.
      // We won't be able to read the response body, but the request reaches the script.
      await fetch(SCRIPT_URL, {
        method:  "POST",
        mode:    "no-cors",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body:    payload.toString(),
      });

      // Because no-cors gives us an opaque response, we treat reaching this point as success.
      showStatus(
        "success",
        "✅ <strong>Message sent!</strong> Our team will respond within 24–48 hours. Check your inbox for a confirmation email."
      );
      form.reset();
      tsInput.value = new Date().toISOString();
      form.querySelectorAll(".has-error, .is-valid").forEach(f => {
        f.classList.remove("has-error", "is-valid");
      });
      if (charCountEl) charCountEl.textContent = `0 / ${MAX_CHARS.toLocaleString()}`;
      if (reasonHint)  reasonHint.textContent = "";

    } catch (err) {
      console.error("Submit error:", err);
      showStatus(
        "error",
        `❌ <strong>Could not send your message.</strong> Please email us directly at <a href="mailto:info@actionpathafrica.org">info@actionpathafrica.org</a> or call <a href="tel:+254112916920">+254 112 916 920</a>.`
      );
    } finally {
      submitBtn.disabled = false;
      submitBtn.classList.remove("loading");
    }
  });

  // ── FAQ ACCORDION ─────────────────────────────────────────────────────────
  document.querySelectorAll(".faq-item").forEach(item => {
    item.addEventListener("toggle", function () {
      if (this.open) {
        document.querySelectorAll(".faq-item").forEach(other => {
          if (other !== this) other.open = false;
        });
      }
    });
  });

  // ── SMOOTH SCROLL ─────────────────────────────────────────────────────────
  document.querySelectorAll(".scroll-to-form").forEach(link => {
    link.addEventListener("click", e => {
      e.preventDefault();
      document.getElementById("contact-form")?.scrollIntoView({ behavior: "smooth" });
    });
  });

})();
</script>