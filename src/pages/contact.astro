  .office-row strong { font-size: .88rem; color: var(--ink); }
  .office-row p  { font-size: .82rem; line-height: 1.65; color: var(--ink-60); margin: .35rem 0; }
  .office-row a  { font-size: .82rem; color: var(--red); text-decoration: none; display: flex; align-items: center; gap: 5px; }
  .office-row a:hover { text-decoration: underline; }
  .map-link { margin-top: .4rem; font-weight: 600 !important; font-size: .8rem !important; }

  /* hours */
  .hours-list  { list-style: none; padding: 0; margin: 0 0 .8rem; display: flex; flex-direction: column; gap: .55rem; }
  .hours-list li { display: flex; justify-content: space-between; font-size: .83rem; }
  .hours-list li span  { color: var(--ink-60); }
  .hours-list li strong { color: var(--ink); }
  .response-note {
    font-size: .75rem; color: var(--ink-60);
    display: flex; align-items: center; gap: 6px;
    border-top: 1px solid var(--border); padding-top: .7rem;
