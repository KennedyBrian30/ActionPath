---
// index.astro - Redesigned Homepage for ActionPath Africa
import Layout from "../layouts/Layout.astro";

const heroImages = [
  "/hero-community-1.webp",
  "/hero-livelihood-2.webp",
  "/hero-training-3.webp",
  "/hero-empowerment-4.webp",
  "/hero-resilience-5.webp",
];

const partners = [
  { name: "UNDP Africa", logo: "🌍" },
  { name: "African Union", logo: "⭐" },
  { name: "Mastercard Foundation", logo: "💳" },
  { name: "USAID", logo: "🇺🇸" },
  { name: "World Bank Group", logo: "🏦" },
  { name: "African Development Bank", logo: "🌱" },
];

const stats = [
  { value: "15,000+", label: "Lives Transformed", icon: "fas fa-heart" },
  { value: "28", label: "Communities Reached", icon: "fas fa-globe-africa" },
  { value: "87%", label: "Income Improvement", icon: "fas fa-chart-line" },
  { value: "250+", label: "Livelihood Projects", icon: "fas fa-hands-helping" },
];

const livelihoodPrograms = [
  {
    title: "Agriculture & Climate Resilient Practices",
    description: "Empowering farmers with drought-resistant crops, climate-smart agriculture, and sustainable land management to combat food insecurity.",
    image: "/agriculture-climate.webp",
    icon: "fas fa-seedling",
    tag: "Climate Action",
    href: "/programs/agriculture-climate",
  },
  {
    title: "Entrepreneurship & SME Development",
    description: "Building business acumen, access to micro-finance, and market linkages for community-owned enterprises in conflict-affected regions.",
    image: "/entrepreneurship.webp",
    icon: "fas fa-chart-line",
    tag: "Economic Empowerment",
    href: "/programs/entrepreneurship",
  },
  {
    title: "Livelihood Diversification",
    description: "Helping vulnerable households develop multiple income streams to build resilience against economic shocks and climate variability.",
    image: "/diversification.webp",
    icon: "fas fa-exchange-alt",
    tag: "Resilience Building",
    href: "/programs/livelihood-diversification",
  },
  {
    title: "Vocational & Technical Skills",
    description: "Market-driven trades training — from solar installation to tailoring — creating sustainable employment in underserved communities.",
    image: "/vocational-skills.webp",
    icon: "fas fa-tools",
    tag: "Skills Development",
    href: "/programs/vocational-skills",
  },
  {
    title: "Women & Youth Empowerment",
    description: "Targeted programs addressing unique barriers faced by women and youth, including HIV-affected households and conflict-displaced persons.",
    image: "/women-youth.webp",
    icon: "fas fa-female",
    tag: "Inclusive Growth",
    href: "/programs/women-youth",
  },
];

const consultancyServices = [
  {
    title: "CBO Support & Capacity Building",
    description: "Strengthening community-based organizations with governance, financial management, and program design skills.",
    icon: "fas fa-hand-holding-heart",
    image: "/consultancy-cbo.webp",
    href: "/services/cbo-capacity-building",
  },
  {
    title: "Monitoring & Evaluation Services",
    description: "Impact assessment, data-driven decision making, and outcome tracking for livelihood programs.",
    icon: "fas fa-chart-bar",
    image: "/consultancy-me.webp",
    href: "/services/monitoring-evaluation",
  },
  {
    title: "Strategic Planning & Management",
    description: "Helping organizations design sustainable strategies for community development.",
    icon: "fas fa-project-diagram",
    image: "/consultancy-strategy.webp",
    href: "/services/strategic-planning",
  },
  {
    title: "Feasibility & Market Research",
    description: "Understanding local economies, value chains, and opportunities for livelihood interventions.",
    icon: "fas fa-file-alt",
    image: "/consultancy-research.webp",
    href: "/services/feasibility-research",
  },
];

const corporateServices = [
  {
    title: "Project Management Training",
    description: "Certified PMP and agile methodologies for development sector professionals.",
    icon: "fas fa-tasks",
    image: "/corporate-pmp.webp",
    href: "/services/project-management",
  },
  {
    title: "Monitoring & Evaluation for Corporates",
    description: "CSR impact measurement and social return on investment frameworks.",
    icon: "fas fa-chart-simple",
    image: "/corporate-me.webp",
    href: "/services/corporate-me",
  },
  {
    title: "Human Resource Management",
    description: "Talent development, performance management, and organizational culture.",
    icon: "fas fa-users",
    image: "/corporate-hr.webp",
    href: "/services/human-resources",
  },
  {
    title: "Customer Experience Excellence",
    description: "Service delivery standards for community-facing programs.",
    icon: "fas fa-headset",
    image: "/corporate-cx.webp",
    href: "/services/customer-experience",
  },
  {
    title: "Corporate Governance Training",
    description: "Board leadership, ethics, and compliance for NGOs and social enterprises.",
    icon: "fas fa-gavel",
    image: "/corporate-governance.webp",
    href: "/services/corporate-governance",
  },
];

const testimonials = [
  {
    quote: "ActionPath Africa taught me climate-smart farming. Now my family eats three meals a day even during drought season. I've trained 50 other farmers in my village.",
    name: "Jane Akinyi",
    role: "Smallholder Farmer, Siaya County",
    location: "🇰🇪 Kenya",
    challenge: "Drought & Food Insecurity",
  },
  {
    quote: "After conflict displaced my family, I had nothing. The vocational training gave me tailoring skills. Today I employ 5 women from my community, some living with HIV.",
    name: "Marie Uwimana",
    role: "Tailoring Business Owner",
    location: "🇷🇼 Rwanda",
    challenge: "Post-Conflict Recovery",
  },
  {
    quote: "The youth empowerment program transformed me from street hawker to agri-preneur. I now run a vegetable farm supplying local schools.",
    name: "Ahmed Hassan",
    role: "Youth Agri-Entrepreneur",
    location: "🇪🇹 Ethiopia",
    challenge: "Urban Poverty & Unemployment",
  },
  {
    quote: "Living with HIV, I struggled to find dignified work. ActionPath's livelihood diversification training changed everything. I now run a successful poultry business.",
    name: "Beatrice Mwangi",
    role: "Poultry Farmer",
    location: "🇰🇪 Kenya",
    challenge: "HIV/AIDS & Stigma",
  },
];

const blogPosts = [
  {
    title: "Climate-Smart Agriculture: How Smallholder Farmers in Siaya Are Beating the Drought",
    excerpt: "In Siaya County, Kenya, erratic rainfall once meant failed harvests and hungry families. Discover how ActionPath Africa's climate-resilient farming program is rewriting that story — one farmer at a time.",
    image: "/blog-climate-farming.webp",
    category: "Agriculture",
    categoryIcon: "fas fa-seedling",
    date: "June 12, 2025",
    readTime: "5 min read",
    author: "ActionPath Editorial",
    href: "/blog/climate-smart-agriculture-siaya",
  },
  {
    title: "From Conflict to Commerce: Youth Entrepreneurs Rebuilding Communities in Post-Conflict Zones",
    excerpt: "Three years after displacement, a cohort of young entrepreneurs in Rwanda and Ethiopia are not just surviving — they are building businesses that anchor their communities. Here is their journey.",
    image: "/blog-youth-enterprise.webp",
    category: "Entrepreneurship",
    categoryIcon: "fas fa-chart-line",
    date: "May 28, 2025",
    readTime: "7 min read",
    author: "ActionPath Editorial",
    href: "/blog/youth-entrepreneurs-post-conflict",
  },
  {
    title: "Breaking the Stigma: Dignified Livelihoods for HIV-Affected Households",
    excerpt: "Stigma is often a bigger barrier than the disease itself. ActionPath Africa's holistic livelihood model is proving that with the right support, HIV-affected households can achieve lasting economic independence.",
    image: "/blog-hiv-livelihoods.webp",
    category: "Health & Livelihoods",
    categoryIcon: "fas fa-heart",
    date: "April 15, 2025",
    readTime: "6 min read",
    author: "ActionPath Editorial",
    href: "/blog/dignified-livelihoods-hiv-households",
  },
];

const challenges = [
  {
    icon: "🌾",
    title: "Drought & Hunger",
    description: "Climate-resilient agriculture, food security programs, and drought adaptation strategies.",
    href: "/focus-areas/drought-hunger",
  },
  {
    icon: "⚔️",
    title: "Conflict & Displacement",
    description: "Post-conflict recovery, livelihood restoration, and trauma-informed economic empowerment.",
    href: "/focus-areas/conflict-displacement",
  },
  {
    icon: "🏚️",
    title: "Extreme Poverty",
    description: "Graduation approach programs combining asset transfer, skills training, and savings groups.",
    href: "/focus-areas/extreme-poverty",
  },
  {
    icon: "🩺",
    title: "HIV/AIDS & Health Vulnerabilities",
    description: "Dignified livelihoods for affected households, reducing stigma and building economic security.",
    href: "/focus-areas/hiv-aids",
  },
];
---

<Layout
  title="ActionPath Africa | Livelihood Transformation for Resilient Communities"
  description="Empowering communities affected by conflict, drought, poverty, and disease through sustainable livelihood training and capacity building across Africa."
>

  <!-- ═══════════════════════════════════════ -->
  <!-- HERO SECTION                            -->
  <!-- ═══════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-gallery">
      {heroImages.map((img, idx) => (
        <div
          class="hero-slide"
          style={`background-image: url('${img}'); animation-delay: ${idx * 3}s;`}
        ></div>
      ))}
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Transforming Lives Across Africa
      </div>
      <h1>
        <span class="hero-highlight">Building resilient</span><br />
        livelihoods for<br />
        <span class="hero-sub">communities in crisis</span>
      </h1>
      <p class="hero-desc">
        ActionPath Africa empowers communities affected by conflict, drought, hunger, poverty, and
        HIV/AIDS through sustainable livelihood training, economic opportunities, and psychosocial
        support.
      </p>
      <div class="hero-buttons">
        <a href="#programs" class="btn-primary">
          <i class="fas fa-hands-helping"></i> Our Livelihood Programs
        </a>
        <a href="/contact" class="btn-outline">
          <i class="fas fa-handshake"></i> Partner With Us
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ -->
  <!-- IMPACT STATS                            -->
  <!-- ═══════════════════════════════════════ -->
  <section class="stats-strip">
    {
      stats.map((stat) => (
        <div class="stat-item" key={stat.label}>
          <i class={stat.icon} />
          <div class="stat-number">{stat.value}</div>
          <div class="stat-label">{stat.label}</div>
        </div>
      ))
    }
  </section>

  <!-- ═══════════════════════════════════════ -->
  <!-- WELCOME SECTION (condensed)             -->
  <!-- ═══════════════════════════════════════ -->
  <section class="welcome-section">
    <div class="welcome-grid">
      <div class="welcome-text">
        <div class="section-eyebrow"><i class="fas fa-compass"></i> Our Purpose</div>
        <h2>Welcome to <span class="accent-text">ActionPath Africa</span></h2>
        <div class="section-divider left"></div>
        <p class="welcome-intro">
          ActionPath Africa designs and delivers transformative livelihood training programs that
          equip youth, women, and marginalized communities with practical skills, entrepreneurial
          confidence, and the psychosocial resilience to break cycles of poverty — whether caused by
          conflict, drought, disease, or displacement.
        </p>
        <p>
          Our approach is holistic and context-specific: from climate-smart agriculture and
          vocational trades to SME development and trauma-informed counseling, every program is
          built in partnership with communities and aligned to national development strategies —
          ensuring impact that lasts well beyond donor cycles.
        </p>
        <a href="/about" class="btn-primary btn-about">
          <i class="fas fa-arrow-right"></i> Learn More About Us
        </a>
      </div>
      <div class="welcome-image">
        <img
          src="/welcome-community.webp"
          alt="Empowered community members in training session"
          loading="lazy"
        />
        <div class="welcome-img-caption">
          <i class="fas fa-users"></i> 15,000+ lives transformed across Africa
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ -->
  <!-- LIVELIHOOD PROGRAMS                     -->
  <!-- ═══════════════════════════════════════ -->
  <section id="programs" class="programs-section">
    <div class="section-header">
      <div class="section-eyebrow"><i class="fas fa-seedling"></i> Livelihood Training</div>
      <h2>Our <span class="accent-text">Programs</span></h2>
      <div class="section-divider"></div>
      <p class="section-subtitle">
        Context-specific livelihood interventions designed for communities facing conflict, drought,
        poverty, and disease.
      </p>
    </div>

    <div class="programs-grid">
      {
        livelihoodPrograms.map((program) => (
          <a href={program.href} class="program-card" key={program.title}>
            <div class="program-img-wrap">
              <img
                src={program.image}
                alt={program.title}
                class="program-img"
                loading="lazy"
              />
              <div class="program-tag">{program.tag}</div>
              <div class="program-overlay">
                <span class="program-explore">
                  Learn More <i class="fas fa-arrow-right" />
                </span>
              </div>
            </div>
            <div class="program-body">
              <div class="program-icon-wrap">
                <i class={program.icon} />
              </div>
              <h3 class="program-title">{program.title}</h3>
              <p class="program-desc">{program.description}</p>
              <div class="program-meta">
                <span>
                  <i class="fas fa-graduation-cap" /> Livelihood Track
                </span>
                <span class="program-link">
                  Explore <i class="fas fa-chevron-right" />
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>

    <div class="section-cta-row">
      <a href="/programs" class="btn-outline-dark">
        <i class="fas fa-th-large"></i> View All Programs
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ -->
  <!-- COMMUNITY CHALLENGES WE ADDRESS         -->
  <!-- ═══════════════════════════════════════ -->
  <section class="challenges-section">
    <div class="section-header">
      <div class="section-eyebrow"><i class="fas fa-hand-holding-heart"></i> Where We Work</div>
      <h2>Addressing <span class="accent-text">Critical Challenges</span></h2>
      <div class="section-divider"></div>
      <p class="section-subtitle">
        Our interventions are designed specifically for communities facing multiple, intersecting
        vulnerabilities.
      </p>
    </div>
    <div class="challenges-grid">
      {
        challenges.map((c) => (
          <a href={c.href} class="challenge-card" key={c.title}>
            <div class="challenge-icon">{c.icon}</div>
            <h3>{c.title}</h3>
            <p>{c.description}</p>
            <span class="challenge-link">
              Learn more <i class="fas fa-arrow-right" />
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ═══════════════════════════════════════ -->
  <!-- CONSULTANCY & CORPORATE SERVICES        -->
  <!-- ═══════════════════════════════════════ -->
  <section class="services-section">
    <div class="services-header">
      <div class="section-eyebrow">
        <i class="fas fa-chalkboard-teacher"></i> Capacity Building
      </div>
      <h2>Consultancy & <span class="accent-text">Corporate Services</span></h2>
      <div class="section-divider"></div>
      <p class="section-subtitle">
        Strengthening organizations to better serve vulnerable communities through expert guidance
        and training.
      </p>
    </div>

    <div class="services-two-columns">
      <!-- General Consultancy -->
      <div class="service-category">
        <h3><i class="fas fa-hand-holding-heart"></i> General Consultancy</h3>
        <div class="service-cards-grid">
          {
            consultancyServices.map((service) => (
              <a href={service.href} class="service-card" key={service.title}>
                <div class="service-card-img-wrap">
                  <img src={service.image} alt={service.title} loading="lazy" />
                  <div class="service-card-icon">
                    <i class={service.icon} />
                  </div>
                </div>
                <div class="service-card-body">
                  <strong>{service.title}</strong>
                  <p>{service.description}</p>
                  <span class="service-card-link">
                    Explore <i class="fas fa-arrow-right" />
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </div>

      <!-- Corporate Services -->
      <div class="service-category">
        <h3><i class="fas fa-building"></i> Corporate Services</h3>
        <div class="service-cards-grid">
          {
            corporateServices.map((service) => (
              <a href={service.href} class="service-card" key={service.title}>
                <div class="service-card-img-wrap">
                  <img src={service.image} alt={service.title} loading="lazy" />
                  <div class="service-card-icon">
                    <i class={service.icon} />
                  </div>
                </div>
                <div class="service-card-body">
                  <strong>{service.title}</strong>
                  <p>{service.description}</p>
                  <span class="service-card-link">
                    Explore <i class="fas fa-arrow-right" />
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <div class="section-cta-row">
      <a href="/services" class="btn-outline-dark">
        <i class="fas fa-briefcase"></i> View All Services
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ -->
  <!-- TESTIMONIALS                            -->
  <!-- ═══════════════════════════════════════ -->
  <section class="testimonials-section">
    <div class="section-header">
      <div class="section-eyebrow"><i class="fas fa-quote-left"></i> Community Voices</div>
      <h2>Stories of <span class="accent-text">Transformation</span></h2>
      <div class="section-divider"></div>
      <p class="section-subtitle">Real impact from the communities we serve across Africa</p>
    </div>
    <div class="testimonials-grid">
      {
        testimonials.map((t) => (
          <div class="testimonial-card" key={t.name}>
            <div class="testi-quote-icon">
              <i class="fas fa-quote-left" />
            </div>
            <p class="testi-text">"{t.quote}"</p>
            <div class="testi-challenge">
              <span class="challenge-badge">{t.challenge}</span>
            </div>
            <div class="testi-author">
              <div class="testi-flag">{t.location}</div>
              <div>
                <div class="testi-name">{t.name}</div>
                <div class="testi-role">{t.role}</div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ═══════════════════════════════════════ -->
  <!-- BLOG SECTION                            -->
  <!-- ═══════════════════════════════════════ -->
  <section class="blog-section">
    <div class="section-header">
      <div class="section-eyebrow"><i class="fas fa-newspaper"></i> Latest Insights</div>
      <h2>From the <span class="accent-text">Field</span></h2>
      <div class="section-divider"></div>
      <p class="section-subtitle">
        Stories, research, and lessons from our work across Africa's most vulnerable communities.
      </p>
    </div>

    <div class="blog-grid">
      {
        blogPosts.map((post, idx) => (
          <a href={post.href} class={`blog-card ${idx === 0 ? "blog-card--featured" : ""}`} key={post.title}>
            <div class="blog-img-wrap">
              <img src={post.image} alt={post.title} loading="lazy" />
              <div class="blog-category">
                <i class={post.categoryIcon} />
                {post.category}
              </div>
            </div>
            <div class="blog-body">
              <div class="blog-meta">
                <span><i class="fas fa-calendar-alt" /> {post.date}</span>
                <span><i class="fas fa-clock" /> {post.readTime}</span>
              </div>
              <h3 class="blog-title">{post.title}</h3>
              <p class="blog-excerpt">{post.excerpt}</p>
              <div class="blog-footer">
                <span class="blog-author">
                  <i class="fas fa-pen" /> {post.author}
                </span>
                <span class="blog-read-link">
                  Read more <i class="fas fa-arrow-right" />
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>

    <div class="section-cta-row">
      <a href="/blog" class="btn-outline-dark">
        <i class="fas fa-newspaper"></i> View All Articles
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ -->
  <!-- PARTNERS                                -->
  <!-- ═══════════════════════════════════════ -->
  <section class="partners-section">
    <div class="section-header">
      <div class="section-eyebrow"><i class="fas fa-handshake"></i> Our Network</div>
      <h2>Trusted by <span class="accent-text">Global Partners</span></h2>
      <div class="section-divider"></div>
      <p class="section-subtitle">Collaborating with leading organizations to amplify impact</p>
    </div>
    <div class="partner-grid">
      {
        partners.map((partner) => (
          <div class="partner-card" key={partner.name}>
            <span class="partner-emoji">{partner.logo}</span>
            <span>{partner.name}</span>
          </div>
        ))
      }
    </div>
    <p class="partner-cta">
      <i class="fas fa-plus-circle"></i> Join us in building resilient communities
      <a href="/contact" class="partner-link">Become a partner →</a>
    </p>
  </section>

  <!-- ═══════════════════════════════════════ -->
  <!-- DELIVERY MODES                          -->
  <!-- ═══════════════════════════════════════ -->
  <section class="modes-section">
    <div class="section-header">
      <div class="section-eyebrow"><i class="fas fa-sliders-h"></i> How We Deliver</div>
      <h2>Flexible <span class="accent-text">Approaches</span></h2>
      <div class="section-divider"></div>
    </div>
    <div class="modes-grid">
      <a href="/delivery/community-training" class="mode-card">
        <div class="mode-icon-big"><i class="fas fa-chalkboard-user"></i></div>
        <div class="mode-body">
          <h3>Community-Based Training</h3>
          <p>On-the-ground programs delivered within communities, respecting local contexts and cultural norms.</p>
          <span class="mode-link">Learn more <i class="fas fa-arrow-right"></i></span>
        </div>
      </a>
      <a href="/delivery/remote-learning" class="mode-card">
        <div class="mode-icon-big"><i class="fas fa-laptop"></i></div>
        <div class="mode-body">
          <h3>Remote & Hybrid Learning</h3>
          <p>Accessible digital platforms reaching remote communities with limited infrastructure.</p>
          <span class="mode-link">Learn more <i class="fas fa-arrow-right"></i></span>
        </div>
      </a>
      <a href="/delivery/train-the-trainer" class="mode-card">
        <div class="mode-icon-big"><i class="fas fa-users"></i></div>
        <div class="mode-body">
          <h3>Train-the-Trainer Model</h3>
          <p>Building local capacity for sustainable, community-led knowledge transfer.</p>
          <span class="mode-link">Learn more <i class="fas fa-arrow-right"></i></span>
        </div>
      </a>
      <a href="/delivery/partnerships" class="mode-card">
        <div class="mode-icon-big"><i class="fas fa-building"></i></div>
        <div class="mode-body">
          <h3>Organizational Partnerships</h3>
          <p>Tailored programs for NGOs, government agencies, and private sector partners.</p>
          <span class="mode-link">Learn more <i class="fas fa-arrow-right"></i></span>
        </div>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ -->
  <!-- NEWSLETTER SIGNUP                       -->
  <!-- ═══════════════════════════════════════ -->
  <section class="newsletter-section">
    <div class="newsletter-inner">
      <div class="newsletter-text">
        <div class="section-eyebrow light"><i class="fas fa-envelope-open-text"></i> Stay Connected</div>
        <h2>Get impact stories <span class="accent-green-text">straight to your inbox</span></h2>
        <p>Monthly updates on our programs, community voices, and opportunities to get involved.</p>
