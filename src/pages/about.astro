---
// about.astro — About Us page for ActionPath Africa
import Layout from "../layouts/Layout.astro";

const values = [
  {
    icon: "fas fa-heart",
    title: "Community First",
    description:
      "Every decision we make is filtered through one question: does this serve the community? We center the voices, needs, and dignity of the people we work with above all else.",
  },
  {
    icon: "fas fa-seedling",
    title: "Holistic Transformation",
    description:
      "We address poverty not as a single problem but as an ecosystem of challenges — economic, social, psychological, and environmental — and respond with equally integrated solutions.",
  },
  {
    icon: "fas fa-handshake",
    title: "Collaborative Partnerships",
    description:
      "We believe lasting change is built together. We co-design programs with communities, governments, NGOs, and the private sector to ensure relevance, ownership, and sustainability.",
  },
  {
    icon: "fas fa-chart-line",
    title: "Evidence & Accountability",
    description:
      "Impact must be measurable. We invest in rigorous monitoring, evaluation, and learning systems to ensure every shilling of resources translates to real, documented change.",
  },
  {
    icon: "fas fa-shield-alt",
    title: "Dignity & Inclusion",
    description:
      "We design with and for the most marginalized — women, youth, people living with HIV/AIDS, displaced communities — ensuring no one is left behind in the path to prosperity.",
  },
  {
    icon: "fas fa-lightbulb",
    title: "Contextual Innovation",
    description:
      "Africa's challenges demand Africa-shaped solutions. We adapt global best practices to local realities, continuously learning and evolving our approaches based on what works on the ground.",
  },
];

const milestones = [
  {
    year: "2015",
    title: "ActionPath Africa Founded",
    description:
      "Established in Nairobi by a team of development practitioners committed to redefining livelihood training in East Africa.",
  },
  {
    year: "2017",
    title: "First Regional Expansion",
    description:
      "Launched operations in Rwanda and Ethiopia, extending our reach to post-conflict and drought-affected communities.",
  },
  {
    year: "2019",
    title: "10,000 Beneficiaries Milestone",
    description:
      "Crossed the landmark of 10,000 lives directly impacted through livelihood programs, vocational training, and economic empowerment.",
  },
  {
    year: "2021",
    title: "Strategic Partnership with UNDP",
    description:
      "Formalized a multi-year partnership with UNDP Africa to deliver climate-resilient agriculture programs across six counties in Kenya.",
  },
  {
    year: "2023",
    title: "Accra Office Opened",
    description:
      "Expanded into West Africa with a new office in Accra, Ghana, broadening our continental footprint and delivery capacity.",
  },
  {
    year: "2025",
    title: "15,000+ Lives Transformed",
    description:
      "Reached our most ambitious milestone yet — over 15,000 individuals transformed, 250+ projects delivered, and 28 communities served across Africa.",
  },
];

const team = [
  {
    name: "Dr. Amara Osei",
    role: "Executive Director",
    bio: "20+ years in international development. Former UNDP programme specialist with deep expertise in livelihoods and community resilience across Sub-Saharan Africa.",
    image: "/team-amara.webp",
    linkedin: "#",
    flag: "🇬🇭",
  },
  {
    name: "Faith Njoroge",
    role: "Director of Programs",
    bio: "Specialist in gender-responsive livelihood design and climate adaptation. Led programs reaching 50,000+ smallholder farmers across Kenya and Tanzania.",
    image: "/team-faith.webp",
    linkedin: "#",
    flag: "🇰🇪",
  },
  {
    name: "Jean-Pierre Habimana",
    role: "Head of Consultancy",
    bio: "Expert in M&E, organizational capacity building, and post-conflict reconstruction. Formerly with the African Development Bank and GIZ Rwanda.",
    image: "/team-jean.webp",
    linkedin: "#",
    flag: "🇷🇼",
  },
  {
    name: "Amina Warsame",
    role: "Director of Partnerships",
    bio: "Drives institutional relationships with INGOs, UN agencies, and the private sector. 15 years mobilizing resources for East and Horn of Africa initiatives.",
    image: "/team-amina.webp",
    linkedin: "#",
    flag: "🇸🇴",
  },
  {
    name: "Kofi Mensah",
    role: "Head of Corporate Services",
    bio: "Certified PMP and organizational development specialist. Leads our growing portfolio of corporate training and CSR impact measurement services.",
    image: "/team-kofi.webp",
    linkedin: "#",
    flag: "🇬🇭",
  },
  {
    name: "Dr. Beatrice Auma",
    role: "Head of Research & Learning",
    bio: "Leads our evidence and learning agenda. PhD in Development Economics; published researcher on youth entrepreneurship and economic graduation models.",
    image: "/team-beatrice.webp",
    linkedin: "#",
    flag: "🇺🇬",
  },
];

const clients = [
  { name: "UNDP Africa", logo: "🌍", category: "UN Agency" },
  { name: "African Union", logo: "⭐", category: "Continental Body" },
  { name: "Mastercard Foundation", logo: "💳", category: "Foundation" },
  { name: "USAID", logo: "🇺🇸", category: "Bilateral Donor" },
  { name: "World Bank Group", logo: "🏦", category: "Multilateral" },
  {
    name: "African Development Bank",
    logo: "🌱",
    category: "Development Bank",
  },
  { name: "GIZ", logo: "🇩🇪", category: "Technical Cooperation" },
  { name: "Oxfam Africa", logo: "🤝", category: "INGO" },
];

const stats = [
  { value: "15,000+", label: "Lives Transformed", icon: "fas fa-heart" },
  { value: "28", label: "Communities Reached", icon: "fas fa-globe-africa" },
  { value: "87%", label: "Avg. Income Improvement", icon: "fas fa-chart-line" },
  { value: "250+", label: "Projects Delivered", icon: "fas fa-hands-helping" },
  { value: "10", label: "Years of Impact", icon: "fas fa-calendar-check" },
  { value: "6", label: "Countries Active", icon: "fas fa-map-marked-alt" },
];
---

<Layout
  title="About Us | ActionPath Africa"
  description="Learn about ActionPath Africa's mission, story, values, team, and decade of transformative impact across communities affected by conflict, drought, poverty, and disease."
>
  <!-- ══════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════ -->
  <section class="about-hero">
    <div class="about-hero-bg">
      <img src="/about-hero.webp" alt="ActionPath Africa team in the field" />
      <div class="about-hero-overlay"></div>
    </div>
    <div class="about-hero-content">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <i class="fas fa-chevron-right"></i>
        <span>About Us</span>
      </div>
      <div class="hero-eyebrow">
        <span class="eyebrow-dot"></span>
        Our Story
      </div>
      <h1>
        A decade of<br />
        <span class="hero-accent">designing change</span><br />
        across Africa
      </h1>
      <p>
        Founded in 2015, ActionPath Africa has grown from a small Nairobi-based
        training organisation into a continent-spanning force for livelihood
        transformation — reaching over 15,000 lives across 28 communities in 6
        countries.
      </p>
      <div class="hero-scroll-hint">
        <i class="fas fa-arrow-down"></i>
        <span>Scroll to discover our story</span>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       IMPACT STATS BAR
  ══════════════════════════════════════════════ -->
  <section class="about-stats">
    {
      stats.map((s) => (
        <div class="astat-item">
          <i class={s.icon} />
          <div class="astat-val">{s.value}</div>
          <div class="astat-lbl">{s.label}</div>
        </div>
      ))
    }
  </section>

  <!-- ══════════════════════════════════════════════
       WHO WE ARE
  ══════════════════════════════════════════════ -->
  <section class="who-section">
    <div class="who-grid">
      <div class="who-images">
        <div class="who-img-main">
          <img
            src="/about-field-1.webp"
            alt="ActionPath team working with community"
            loading="lazy"
          />
        </div>
        <div class="who-img-secondary">
          <img
            src="/about-field-2.webp"
            alt="Training session in progress"
            loading="lazy"
          />
          <div class="who-badge">
            <i class="fas fa-award"></i>
            <span>10 Years of Impact</span>
          </div>
        </div>
      </div>

      <div class="who-text">
        <div class="section-eyebrow">
          <i class="fas fa-compass"></i> Who We Are
        </div>
        <h2>
          More than training — <span class="accent-red"
            >a movement for change</span>
        </h2>
        <div class="divider-line"></div>
        <p class="who-lead">
          ActionPath Africa is a Pan-African livelihood training, consultancy,
          and capacity building organisation committed to transforming the
          trajectories of communities living at the intersection of poverty,
          climate vulnerability, conflict, and disease.
        </p>
        <p>
          We work where others struggle to — in post-conflict zones,
          drought-stricken landscapes, urban slums, and HIV-affected households
          — delivering practical, context-specific programs that give
          individuals not just skills, but agency, dignity, and economic
          pathways.
        </p>
        <p>
          Our model is built on three pillars: <strong
            >rigorous curriculum design</strong
          >,
          <strong>participatory community engagement</strong>, and
          <strong>sustainable institutional partnerships</strong>. Together
          these pillars ensure our programs outlast donor funding, embed within
          local systems, and create ripple effects across entire communities.
        </p>
        <div class="who-highlights">
          <div class="who-hl">
            <i class="fas fa-check-circle"></i>
            <span>Community-owned, market-linked livelihood programs</span>
          </div>
          <div class="who-hl">
            <i class="fas fa-check-circle"></i>
            <span
              >Accredited training aligned to national qualifications frameworks</span
            >
          </div>
          <div class="who-hl">
            <i class="fas fa-check-circle"></i>
            <span>Psychosocial support integrated into all programs</span>
          </div>
          <div class="who-hl">
            <i class="fas fa-check-circle"></i>
            <span>Gender-responsive and youth-inclusive by design</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       MISSION / VISION / APPROACH
  ══════════════════════════════════════════════ -->
  <section class="mvp-section">
    <div class="mvp-grid">
      <div class="mvp-card mvp-mission">
        <div class="mvp-icon"><i class="fas fa-bullseye"></i></div>
        <h3>Our Mission</h3>
        <p>
          To empower marginalized communities across Africa through innovative,
          context-specific livelihood training and strategic capacity building —
          creating sustainable pathways out of poverty, vulnerability, and
          exclusion.
        </p>
      </div>

      <div class="mvp-card mvp-vision">
        <div class="mvp-icon"><i class="fas fa-eye"></i></div>
        <h3>Our Vision</h3>
        <p>
          A resilient, equitable Africa where every individual — regardless of
          geography, gender, health status, or circumstance — has access to
          dignified economic opportunity and the tools to build a
          self-determined future.
        </p>
      </div>

      <div class="mvp-card mvp-approach">
        <div class="mvp-icon"><i class="fas fa-route"></i></div>
        <h3>Our Approach</h3>
        <p>
          Holistic, evidence-based, and rooted in community realities. We
          combine practical skills training with entrepreneurial development,
          psychosocial support, and systemic institutional partnerships —
          ensuring impact that lasts beyond donor cycles.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       OUR VALUES
  ══════════════════════════════════════════════ -->
  <section class="values-section">
    <div class="section-header">
      <div class="section-eyebrow">
        <i class="fas fa-star"></i> What Guides Us
      </div>
      <h2>Our Core <span class="accent-red">Values</span></h2>
      <div class="divider-center"></div>
      <p class="section-subtitle">
        Six principles that shape every program, partnership, and decision we
        make.
      </p>
    </div>
    <div class="values-grid">
      {
        values.map((v, i) => (
          <div class="value-card" style={`animation-delay: ${i * 0.08}s`}>
            <div class="value-num">{String(i + 1).padStart(2, "0")}</div>
            <div class="value-icon">
              <i class={v.icon} />
            </div>
            <h3>{v.title}</h3>
            <p>{v.description}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       TIMELINE / MILESTONES
  ══════════════════════════════════════════════ -->
  <section class="timeline-section">
    <div class="section-header">
      <div class="section-eyebrow">
        <i class="fas fa-history"></i> Our Journey
      </div>
      <h2>A Decade of <span class="accent-red">Milestones</span></h2>
      <div class="divider-center"></div>
      <p class="section-subtitle">
        From a bold idea in Nairobi to a continental force for change.
      </p>
    </div>

    <div class="timeline">
      {
        milestones.map((m, i) => (
          <div
            class={`timeline-item ${i % 2 === 0 ? "tl-left" : "tl-right"}`}
            key={m.year}
          >
            <div class="tl-content">
              <div class="tl-year">{m.year}</div>
              <h3 class="tl-title">{m.title}</h3>
              <p class="tl-desc">{m.description}</p>
            </div>
            <div class="tl-dot">
              <i class="fas fa-circle-dot" />
            </div>
          </div>
        ))
      }
      <div class="timeline-line"></div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       LEADERSHIP TEAM
  ══════════════════════════════════════════════ -->
  <section class="team-section">
    <div class="section-header">
      <div class="section-eyebrow"><i class="fas fa-users"></i> Leadership</div>
      <h2>Meet the <span class="accent-red">Team</span></h2>
      <div class="divider-center"></div>
      <p class="section-subtitle">
        Passionate practitioners, researchers, and development leaders driving
        our mission forward.
      </p>
    </div>

    <div class="team-grid">
      {
        team.map((member) => (
          <div class="team-card" key={member.name}>
            <div class="team-img-wrap">
              <img src={member.image} alt={member.name} loading="lazy" />
              <div class="team-flag">{member.flag}</div>
              <div class="team-overlay">
                <a
                  href={member.linkedin}
                  class="team-li"
                  aria-label={`${member.name} on LinkedIn`}
                >
                  <i class="fab fa-linkedin-in" />
                </a>
              </div>
            </div>
            <div class="team-body">
              <h3 class="team-name">{member.name}</h3>
              <div class="team-role">{member.role}</div>
              <p class="team-bio">{member.bio}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="team-cta-row">
      <a href="/about/team" class="btn-outline-dark">
        <i class="fas fa-users"></i> View Full Team
      </a>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       CLIENTS & PARTNERS
  ══════════════════════════════════════════════ -->
  <section class="clients-section">
    <div class="section-header">
      <div class="section-eyebrow">
        <i class="fas fa-handshake"></i> Who We Work With
      </div>
      <h2>Trusted by <span class="accent-red">Leading Partners</span></h2>
      <div class="divider-center"></div>
      <p class="section-subtitle">
        We collaborate with UN agencies, bilateral donors, foundations, INGOs,
        and the private sector to amplify our reach and deepen our impact.
      </p>
    </div>

    <div class="clients-grid">
      {
        clients.map((c) => (
          <div class="client-card" key={c.name}>
            <div class="client-logo">{c.logo}</div>
            <div class="client-name">{c.name}</div>
            <div class="client-category">{c.category}</div>
          </div>
        ))
      }
    </div>

    <div class="clients-cta">
      <a href="/about/clients" class="btn-outline-dark">
        <i class="fas fa-briefcase"></i> View All Clients & Portfolio
      </a>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       FINAL CTA
  ══════════════════════════════════════════════ -->
  <section class="about-cta">
    <div class="about-cta-inner">
      <div class="about-cta-bg">
        <img
          src="/about-cta-bg.webp"
          alt=""
          aria-hidden="true"
          loading="lazy"
        />
        <div class="about-cta-overlay"></div>
      </div>
      <div class="about-cta-content">
        <div class="section-eyebrow light">
          <i class="fas fa-bolt"></i> Get Involved
        </div>
        <h2>Ready to <span class="cta-green">build change</span> together?</h2>
        <p>
          Whether you're an NGO, government agency, donor, or community leader —
          there's a role for you in ActionPath Africa's ecosystem of
          transformation.
        </p>
        <div class="about-cta-buttons">
          <a href="/contact" class="btn-white">
            <i class="fas fa-envelope"></i> Partner With Us
          </a>
          <a href="/programs" class="btn-outline-white">
            <i class="fas fa-seedling"></i> Explore Our Programs
          </a>
          <a href="/impact-report" class="btn-outline-white">
            <i class="fas fa-download"></i> Download Impact Report
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ══════════════════════════════════════════════
     ABOUT PAGE STYLES
  ══════════════════════════════════════════════ */

  /* ── Hero ──────────────────────────────────── */
  .about-hero {
    position: relative;
    min-height: 72vh;
    display: flex;
    align-items: flex-end;
    margin: -2.5rem -2rem 0;
    overflow: hidden;
  }

  .about-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .about-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .about-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(15, 23, 42, 0.92) 0%,
      rgba(15, 23, 42, 0.6) 40%,
      rgba(15, 23, 42, 0.25) 100%
    );
  }

  .about-hero-content {
    position: relative;
    z-index: 2;
    padding: 3rem 2rem 3.5rem;
    max-width: 760px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .breadcrumb a {
    color: rgba(255, 255, 255, 0.65);
    transition: color 0.2s;
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--accent-green-light);
  }

  .breadcrumb i {
    font-size: 0.6rem;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(8px);
    color: var(--accent-green-light);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border-radius: 40px;
    margin-bottom: 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .eyebrow-dot {
    width: 7px;
    height: 7px;
    background: var(--accent-green);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(1.3);
    }
  }

  .about-hero-content h1 {
    font-family: "Outfit", sans-serif;
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: white;
    margin-bottom: 1.25rem;
  }

  .hero-accent {
    background: linear-gradient(135deg, var(--accent-green-light), #7fffb8);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
  }

  .about-hero-content p {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.7;
    max-width: 580px;
    margin-bottom: 2rem;
  }

  .hero-scroll-hint {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 500;
  }

  .hero-scroll-hint i {
    animation: bounceY 2s infinite;
    color: var(--accent-green);
  }

  @keyframes bounceY {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(5px);
    }
  }

  /* ── Stats Bar ─────────────────────────────── */
  .about-stats {
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 1rem;
    background: var(--dark-charcoal);
    border-radius: 20px;
    padding: 2rem 2.5rem;
    margin: 2.5rem 0;
  }

  .astat-item {
    text-align: center;
    color: white;
  }

  .astat-item i {
    font-size: 1.5rem;
    color: var(--accent-green-light);
    margin-bottom: 0.5rem;
    display: block;
  }

  .astat-val {
    font-family: "Outfit", sans-serif;
    font-size: 2.1rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    color: white;
  }

  .astat-lbl {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 4px;
    font-weight: 500;
  }

  /* ── Who We Are ────────────────────────────── */
  .who-section {
    padding: 3.5rem 0;
  }

  .who-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .who-images {
    position: relative;
  }

  .who-img-main {
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.14);
  }

  .who-img-main img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
  }

  .who-img-secondary {
    position: absolute;
    bottom: -40px;
    right: -30px;
    width: 52%;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.18);
    border: 4px solid white;
  }

  .who-img-secondary img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }

  .who-badge {
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--primary-red);
    color: white;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.35rem 1rem;
    border-radius: 40px;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .who-text {
    padding-bottom: 2rem;
  }

  .who-text h2 {
    font-family: "Outfit", sans-serif;
    font-size: 2.1rem;
    font-weight: 800;
    letter-spacing: -0.025em;
