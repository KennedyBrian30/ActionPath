---
// /services/training/climate-agriculture.astro
import Layout from "../../../layouts/Layout.astro";

const pageTitle = "Climate-Smart Agriculture Training | ActionPath Africa";
const pageDescription = "Training youth in climate-smart agriculture means moving beyond traditional farming to resilient, data-informed, and business-minded agri-practices that work with the climate, not against it.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main>
    <!-- Hero Section -->
    <section class="cluster-hero">
      <div class="cluster-hero-inner">
        <div class="cluster-breadcrumb">
          <a href="/">Home</a> <i class="fas fa-chevron-right"></i>
          <a href="/services/training">Training Areas</a> <i class="fas fa-chevron-right"></i>
          <span>Climate-Smart Agriculture</span>
        </div>
        <div class="cluster-icon-large">
          <i class="fas fa-seedling"></i>
        </div>
        <h1><span class="accent-red">Climate-Smart Agriculture</span> </h1>
        <p class="cluster-subhead">Climate-Smart Agriculture (CSA) is one of our most critical training areas, given that agriculture employs over 60% of Africa's youth (many informally) and is severely threatened by erratic weather, soil degradation, and pest shifts. Training youth in CSA means moving beyond traditional farming to resilient, data-informed, and business-minded agri-practices that work with the climate, not against it.</p>
        <div class="cluster-ctas">
          <a href="/contact" class="btn-primary"><i class="fas fa-envelope"></i> Enquire Now</a>
          <a href="/services/training" class="btn-outline"><i class="fas fa-arrow-left"></i> All Training Areas</a>
        </div>
      </div>
    </section>

    <!-- Focus Areas Section -->
    <section class="cluster-focus">
      <div class="cluster-container">
        <div class="section-header">
          <div class="section-eyebrow"><i class="fas fa-bullseye"></i> What We Focus On</div>
          <h2><span class="accent-red">Training</span> Topics</h2>
          <div class="section-divider"></div>
        </div>

        <div class="focus-grid">
          <div class="focus-item">Foundational Climate Literacy for Farmers</div>
          <div class="focus-item">Soil Health & Regenerative Practices</div>
          <div class="focus-item">Water-Smart Agriculture</div>
          <div class="focus-item">Agroforestry & Integrated Systems</div>
          <div class="focus-item">Climate-Resilient Crop & Livestock Management</div>
          <div class="focus-item">Post-Harvest & Storage Innovations</div>
          <div class="focus-item">Data & Digital Tools for Smart Farming</div>
          <div class="focus-item">Agri-Business & Market Linkages</div>
          <div class="focus-item">Practical Climate Adaptation Planning</div>
          <div class="focus-item">Gender & Social Inclusion in CSA</div>
        </div>
      </div>
    </section>

    <!-- Hands-on Modules -->
    <section class="cluster-modules">
      <div class="cluster-container">
        <div class="section-header">
          <div class="section-eyebrow"><i class="fas fa-hands"></i> Practical Modules</div>
          <h2>Hands-On <span class="accent-red">Training</span></h2>
          <div class="section-divider"></div>
        </div>

        <div class="modules-grid">
          <div class="module-item">Soil Health</div>
          <div class="module-item">Water Harvesting</div>
          <div class="module-item">Agroforestry</div>
          <div class="module-item">Pest Management</div>
          <div class="module-item">Post-Harvest</div>
          <div class="module-item">Digital Tools</div>
        </div>

        <div class="modules-cta">
          <a href="/contact" class="btn-primary"><i class="fas fa-calendar-alt"></i> Join Next Cohort</a>
        </div>
      </div>
    </section>


    <!-- Related Programs -->
    <section class="cluster-related">
      <div class="cluster-container">
        <div class="related-grid">
          <div class="related-card">
            <i class="fas fa-lightbulb"></i>
            <h3>Design-driven Entrepreneurship</h3>
            <p>Turn your agri-business idea into reality with design thinking.</p>
            <a href="/services/training/entrepreneurship">Learn more →</a>
          </div>
          <div class="related-card">
            <i class="fas fa-users"></i>
            <h3>Youth Employability Skills</h3>
            <p>Build workplace and career skills alongside farming expertise.</p>
            <a href="/services/training/youth-employability">Learn more →</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  .cluster-hero {
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    padding: 4rem 0;
    color: white;
  }
  .cluster-hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .cluster-breadcrumb {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 2rem;
  }
  .cluster-breadcrumb a {
    color: var(--green-lt);
    text-decoration: none;
  }
  .cluster-breadcrumb i {
    font-size: 0.7rem;
    margin: 0 0.5rem;
  }
  .cluster-icon-large {
    font-size: 4rem;
    color: var(--green);
    margin-bottom: 1rem;
  }
  .cluster-hero h1 {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .accent-red { color: var(--red); }
  .cluster-subhead {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.85);
    max-width: 900px;
    margin-bottom: 2rem;
    line-height: 1.5;
  }
  .cluster-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--red), var(--red-dark));
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    font-weight: 700;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(192, 57, 43, 0.4);
  }
  .btn-outline {
    border: 2px solid rgba(255,255,255,0.3);
    background: transparent;
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
  }
  .btn-outline:hover {
    border-color: var(--green);
    background: rgba(39,238,49,0.1);
  }
  .cluster-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--red-soft);
    color: var(--red);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 0.4rem 1.3rem;
    border-radius: 40px;
    margin-bottom: 1rem;
  }
  .section-header h2 {
    font-size: 2rem;
    font-weight: 800;
    color: var(--charcoal);
  }
  .section-divider {
    width: 70px;
    height: 4px;
    background: linear-gradient(90deg, var(--red), var(--green));
    margin: 1rem auto 0;
    border-radius: 2px;
  }
  .cluster-focus, .cluster-modules, .cluster-partners {
    padding: 4rem 0;
    background: white;
  }
  .cluster-modules {
    background: var(--gray-sf);
  }
  .focus-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .focus-item {
    background: var(--gray-sf);
    padding: 1rem 1.25rem;
    border-radius: 12px;
    font-weight: 500;
    color: var(--charcoal);
    border-left: 3px solid var(--red);
  }
  .modules-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .module-item {
    background: white;
    padding: 1rem;
    border-radius: 12px;
    font-weight: 600;
    color: var(--charcoal);
    text-align: center;
    border: 1px solid var(--border);
    transition: all 0.3s ease;
  }
  .module-item:hover {
    background: var(--red-soft);
    border-color: var(--red);
  }
  .modules-cta {
    text-align: center;
    margin-top: 1rem;
  }
  .partners-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .partner-item {
    background: var(--gray-sf);
    padding: 0.9rem 1rem;
    border-radius: 12px;
    font-weight: 500;
    color: var(--charcoal);
    text-align: center;
    font-size: 0.9rem;
  }
  .partner-note {
    background: var(--red-soft);
    padding: 1rem 1.5rem;
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 1rem;
  }
  .partner-note i {
    color: var(--red);
    font-size: 1.2rem;
  }
  .partner-note p {
    margin: 0;
    color: var(--gray-dk);
    font-size: 0.85rem;
  }
  .cluster-related {
    padding: 3rem 0 5rem;
    background: var(--gray-sf);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    max-width: 700px;
    margin: 0 auto;
  }
  .related-card {
    background: white;
    padding: 1.5rem;
    border-radius: 20px;
    text-align: center;
    border: 1px solid var(--border);
  }
  .related-card i {
    font-size: 2rem;
    color: var(--green);
    margin-bottom: 0.75rem;
  }
  .related-card h3 {
    font-size: 1rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: var(--charcoal);
  }
  .related-card p {
    font-size: 0.8rem;
    color: var(--gray-md);
    margin-bottom: 1rem;
  }
  .related-card a {
    color: var(--red);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.85rem;
  }
  .related-card a:hover {
    text-decoration: underline;
  }
  @media (max-width: 768px) {
    .focus-grid { grid-template-columns: 1fr; }
    .modules-grid { grid-template-columns: repeat(2, 1fr); }
    .cluster-hero h1 { font-size: 2rem; }
    .related-grid { grid-template-columns: 1fr; }
    .section-header h2 { font-size: 1.5rem; }
  }
</style>