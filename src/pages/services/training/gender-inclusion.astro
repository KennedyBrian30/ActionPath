---
// /services/training/gender-inclusion.astro
import Layout from "../../../layouts/Layout.astro";

const pageTitle = "Gender & Social Inclusion Training | ActionPath Africa";
const pageDescription = "Training in gender and social inclusion ensures that no young person is left behind because of their gender, disability, ethnicity, religion, HIV status, displacement, or economic background.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main>
    <!-- Hero Section -->
    <section class="cluster-hero">
      <div class="cluster-hero-inner">
        <div class="cluster-breadcrumb">
          <a href="/">Home</a> <i class="fas fa-chevron-right"></i>
          <a href="/services/training">Training Areas</a> <i class="fas fa-chevron-right"></i>
          <span>Gender & Social Inclusion</span>
        </div>
        <div class="cluster-icon-large">
          <i class="fas fa-venus-mars"></i>
        </div>
        <h1 class="all-red">Gender & Social Inclusion</h1>
        <p class="cluster-subhead">At ActionPath Africa, we believe that training in gender and social inclusion ensures that no young person is left behind because of their gender, disability, ethnicity, religion, HIV status, displacement, or economic background.</p>
        <div class="cluster-ctas">
          <a href="/contact" class="btn-primary"><i class="fas fa-envelope"></i> Inquire About Training</a>
          <a href="/services/training" class="btn-outline"><i class="fas fa-arrow-left"></i> All Training Areas</a>
        </div>
      </div>
    </section>

    <!-- Focus Areas Section -->
    <section class="cluster-focus">
      <div class="cluster-container">
        <div class="section-header">
          <div class="section-eyebrow"><i class="fas fa-bullseye"></i> What We Focus On</div>
          <h2>Training <span class="accent-red">Topics</span></h2>
          <div class="section-divider"></div>
        </div>

        <div class="focus-grid">
          <div class="focus-item">Foundational Concepts (Without Jargon Overload)</div>
          <div class="focus-item">Why Gender & Social Inclusion Matter for ActionPath Africa</div>
          <div class="focus-item">Identifying Barriers to Participation & Benefit</div>
          <div class="focus-item">Practical Inclusion Strategies for Training Delivery</div>
          <div class="focus-item">Gender Norms & Power Dynamics</div>
          <div class="focus-item">Disability Inclusion (Not an Afterthought)</div>
          <div class="focus-item">Inclusion of Marginalized Ethnic, Religious, & Displaced Youth</div>
          <div class="focus-item">Sexual & Reproductive Health Rights (SRHR) Linkages</div>
          <div class="focus-item">Preventing & Responding to Gender-Based Violence (GBV)</div>
          <div class="focus-item">Inclusive Leadership & Decision-Making</div>
          <div class="focus-item">Collecting & Using Disaggregated Data</div>
          <div class="focus-item">Gender-Responsive Budgeting</div>
          <div class="focus-item">Inclusive Communication & Language</div>
          <div class="focus-item">Self-Care & Boundaries for Trainers</div>
        </div>

        <div class="focus-cta">
          <a href="/contact" class="btn-primary"><i class="fas fa-calendar-alt"></i> Book a Training Session</a>
        </div>
      </div>
    </section>

    <!-- Related Programs -->
    <section class="cluster-related">
      <div class="cluster-container">
        <div class="related-grid">
          <div class="related-card">
            <i class="fas fa-gavel"></i>
            <h3>Human Rights-Based Approach (HRBA)</h3>
            <p>Equip communities to claim their rights and hold duty-bearers accountable.</p>
            <a href="/services/training/hrba">Learn more →</a>
          </div>
          <div class="related-card">
            <i class="fas fa-hand-holding-heart"></i>
            <h3>How to Establish a CBO</h3>
            <p>Build inclusive community organizations.</p>
            <a href="/services/training/establish-cbo">Learn more →</a>
          </div>
          <div class="related-card">
            <i class="fas fa-users"></i>
            <h3>Youth Employability Skills</h3>
            <p>Build workplace inclusion skills.</p>
            <a href="/services/training/youth-employability">Learn more →</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  .cluster-hero {
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    padding: 4rem 0;
    color: white;
  }
  .cluster-hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .cluster-breadcrumb {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 2rem;
  }
  .cluster-breadcrumb a {
    color: var(--green-lt);
    text-decoration: none;
  }
  .cluster-breadcrumb i {
    font-size: 0.7rem;
    margin: 0 0.5rem;
  }
  .cluster-icon-large {
    font-size: 4rem;
    color: var(--green);
    margin-bottom: 1rem;
  }
  .cluster-hero h1 {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .all-red {
    color: var(--red);
  }
  .accent-red { color: var(--red); }
  .cluster-subhead {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.85);
    max-width: 900px;
    margin-bottom: 2rem;
    line-height: 1.5;
  }
  .cluster-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--red), var(--red-dark));
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    font-weight: 700;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(192, 57, 43, 0.4);
  }
  .btn-outline {
    border: 2px solid rgba(255,255,255,0.3);
    background: transparent;
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
  }
  .btn-outline:hover {
    border-color: var(--green);
    background: rgba(39,238,49,0.1);
  }
  .cluster-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--red-soft);
    color: var(--red);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 0.4rem 1.3rem;
    border-radius: 40px;
    margin-bottom: 1rem;
  }
  .section-header h2 {
    font-size: 2rem;
    font-weight: 800;
    color: var(--charcoal);
  }
  .section-divider {
    width: 70px;
    height: 4px;
    background: linear-gradient(90deg, var(--red), var(--green));
    margin: 1rem auto 0;
    border-radius: 2px;
  }
  .cluster-focus {
    padding: 4rem 0;
    background: white;
  }
  .focus-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .focus-item {
    background: var(--gray-sf);
    padding: 1rem 1.25rem;
    border-radius: 12px;
    font-weight: 500;
    color: var(--charcoal);
    border-left: 3px solid var(--red);
  }
  .focus-cta {
    text-align: center;
    margin-top: 1rem;
  }
  .cluster-related {
    padding: 3rem 0 5rem;
    background: var(--gray-sf);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .related-card {
    background: white;
    padding: 1.5rem;
    border-radius: 20px;
    text-align: center;
    border: 1px solid var(--border);
  }
  .related-card i {
    font-size: 2rem;
    color: var(--green);
    margin-bottom: 0.75rem;
  }
  .related-card h3 {
    font-size: 1rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: var(--charcoal);
  }
  .related-card p {
    font-size: 0.8rem;
    color: var(--gray-md);
    margin-bottom: 1rem;
  }
  .related-card a {
    color: var(--red);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.85rem;
  }
  .related-card a:hover {
    text-decoration: underline;
  }
  @media (max-width: 768px) {
    .focus-grid { grid-template-columns: 1fr; }
    .related-grid { grid-template-columns: 1fr; }
    .cluster-hero h1 { font-size: 2rem; }
    .section-header h2 { font-size: 1.5rem; }
  }
</style>