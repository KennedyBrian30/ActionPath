---
// /services/consultancy/psychosocial-support.astro
import Layout from "../../../layouts/Layout.astro";

const pageTitle = "Counseling Services | ActionPath Africa";
const pageDescription = "Professional licensed counseling services moving beyond general advice into structured clinical intervention. Individual and group counseling for substance use, mental health, and recovery support.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main>
    <!-- Hero Section -->
    <section class="cluster-hero">
      <div class="cluster-hero-inner">
        <div class="cluster-breadcrumb">
          <a href="/">Home</a> <i class="fas fa-chevron-right"></i>
          <a href="/services/consultancy">Consultancy</a> <i class="fas fa-chevron-right"></i>
          <span>Counseling Services</span>
        </div>
        <div class="cluster-icon-large">
          <i class="fas fa-heart"></i>
        </div>
        <h1 class="all-red">Counseling Services</h1>
        <p class="cluster-subhead">As professional licensed counselors, our role moves beyond general advice into structured clinical intervention.</p>
        <div class="cluster-ctas">
          <a href="/contact" class="btn-primary"><i class="fas fa-envelope"></i> Inquire About Counseling</a>
          <a href="/services/consultancy" class="btn-outline"><i class="fas fa-arrow-left"></i> All Consultancy Services</a>
        </div>
      </div>
    </section>

    <!-- Step-by-Step Approach Section -->
    <section class="cluster-approach">
      <div class="cluster-container">
        <div class="section-header">
          <div class="section-eyebrow"><i class="fas fa-steps"></i> Our Method</div>
          <h2>Step-by-Step <span class="accent-red">Counseling Approach</span></h2>
          <div class="section-divider"></div>
        </div>

        <div class="steps-grid">
          <div class="step-card">
            <div class="step-number">01</div>
            <div class="step-icon"><i class="fas fa-handshake"></i></div>
            <h3>Build Trust and Rapport</h3>
            <p>We establish a safe, non-judgmental environment where the client feels heard and respected; use active listening and empathy; avoid stigmatizing language; and validate their feelings and experiences.</p>
          </div>

          <div class="step-card">
            <div class="step-number">02</div>
            <div class="step-icon"><i class="fas fa-clipboard-list"></i></div>
            <h3>Comprehensive Assessment</h3>
            <p>We gather detailed information about the client's substance use, history, and psychosocial context. Explore patterns of substance use and triggers, assess family, social, and occupational impact, and identify co-occurring mental health issues.</p>
          </div>

          <div class="step-card">
            <div class="step-number">03</div>
            <div class="step-icon"><i class="fas fa-file-medical"></i></div>
            <h3>Develop a Personalized Treatment Plan</h3>
            <p>We create a structured plan tailored to the client's needs and recovery goals. Help clients set up short-term sobriety goals, including therapy sessions (individual, group, family), and integrate relapse prevention strategies.</p>
          </div>

          <div class="step-card">
            <div class="step-number">04</div>
            <div class="step-icon"><i class="fas fa-chalkboard-user"></i></div>
            <h3>Provide Psychoeducation</h3>
            <p>We help clients understand addiction as a disorder and its impact on their lives. This involves explaining the cycle of addiction and relapse, teaching coping mechanisms and stress management, and sharing resources for healthy lifestyle changes.</p>
          </div>

          <div class="step-card">
            <div class="step-number">05</div>
            <div class="step-icon"><i class="fas fa-shield-alt"></i></div>
            <h3>Introduce Coping and Relapse Prevention Skills</h3>
            <p>We equip clients with practical tools to manage cravings and avoid relapse, teach mindfulness and urge surfing, role-play high-risk scenarios, and encourage accountability through peer support.</p>
          </div>

          <div class="step-card">
            <div class="step-number">06</div>
            <div class="step-icon"><i class="fas fa-link"></i></div>
            <h3>Connect to External Resources</h3>
            <p>We link clients to community, medical, and social support systems, refer them to rehabilitation centers or support groups, connect them with vocational training or financial counseling, and encourage family involvement in recovery.</p>
          </div>

          <div class="step-card">
            <div class="step-number">07</div>
            <div class="step-icon"><i class="fas fa-chart-line"></i></div>
            <h3>Monitor Progress and Adjust Plans</h3>
            <p>We regularly review the client's progress and adapt interventions as needed, track milestones and setbacks, celebrate small wins with them, and revise treatment plans to fit evolving needs.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Session Outline Section -->
    <section class="cluster-session">
      <div class="cluster-container">
        <div class="section-header">
          <div class="section-eyebrow"><i class="fas fa-calendar-alt"></i> Session Structure</div>
          <h2>Counseling <span class="accent-red">Session Outline</span></h2>
          <div class="section-divider"></div>
        </div>

        <div class="session-grid">
          <div class="session-card">
            <i class="fas fa-users"></i>
            <h3>Group & Individual Plans</h3>
            <p>Step-by-step plans for group and individual counseling, including objectives, activities, and reflection prompts.</p>
          </div>
          <div class="session-card">
            <i class="fas fa-comments"></i>
            <h3>Facilitation Language</h3>
            <p>Suggested language for introducing topics, guiding discussions, and managing sensitive disclosures.</p>
          </div>
          <div class="session-card">
            <i class="fas fa-gamepad"></i>
            <h3>Interactive Exercises</h3>
            <p>Role-plays, journaling, and group reflections to build self-awareness, impulse control, and empathy.</p>
          </div>
          <div class="session-card">
            <i class="fas fa-chalkboard"></i>
            <h3>Psychoeducation Tools</h3>
            <p>Visual aids including the Addiction Iceberg, Johari Window, and Wheel of Life to help clients understand triggers and coping strategies.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Specialized Modules Section -->
    <section class="cluster-modules">
      <div class="cluster-container">
        <div class="section-header">
          <div class="section-eyebrow"><i class="fas fa-cogs"></i> Specialized Modules</div>
          <h2>Recovery & <span class="accent-red">Empowerment</span></h2>
          <div class="section-divider"></div>
        </div>

        <div class="modules-flex">
          <div class="module-block">
            <i class="fas fa-brain"></i>
            <h3>Relapse Prevention Modules</h3>
            <p>Techniques including urge surfing, the DEADS method, and trigger mapping to help clients maintain recovery.</p>
          </div>
          <div class="module-block">
            <i class="fas fa-coins"></i>
            <h3>Financial Empowerment Sessions</h3>
            <p>Discuss budgeting, savings, and vocational training to reduce relapse linked to economic stress.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Evaluation Section -->
    <section class="cluster-evaluation">
      <div class="cluster-container">
        <div class="evaluation-content">
          <i class="fas fa-chart-simple"></i>
          <h3>Program Evaluation</h3>
          <p>We evaluate our program using pre/post assessments, peer accountability checklists, and facilitator reflection logs to ensure continuous improvement and measurable outcomes.</p>
        </div>

        <div class="evaluation-cta">
          <a href="/contact" class="btn-primary"><i class="fas fa-calendar-alt"></i> Schedule a Counseling Session</a>
        </div>
      </div>
    </section>

    <!-- Related Services -->
    <section class="cluster-related">
      <div class="cluster-container">
        <div class="related-grid">
          <div class="related-card">
            <i class="fas fa-chart-line"></i>
            <h3>MEARL Services</h3>
            <p>Measure the impact of your psychosocial programs.</p>
            <a href="/services/consultancy/monitoring-evaluation">Learn more →</a>
          </div>
          <div class="related-card">
            <i class="fas fa-book-open"></i>
            <h3>Curriculum Development</h3>
            <p>Develop psychosocial and counseling training curricula.</p>
            <a href="/services/consultancy/curriculum-development">Learn more →</a>
          </div>
          <div class="related-card">
            <i class="fas fa-heart"></i>
            <h3>Life Skills Training</h3>
            <p>Build emotional regulation and resilience skills.</p>
            <a href="/services/training/life-skills">Learn more →</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  .cluster-hero {
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    padding: 4rem 0;
    color: white;
  }
  .cluster-hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .cluster-breadcrumb {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 2rem;
  }
  .cluster-breadcrumb a {
    color: var(--green-lt);
    text-decoration: none;
  }
  .cluster-breadcrumb i {
    font-size: 0.7rem;
    margin: 0 0.5rem;
  }
  .cluster-icon-large {
    font-size: 4rem;
    color: var(--green);
    margin-bottom: 1rem;
  }
  .cluster-hero h1 {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .all-red {
    color: var(--red);
  }
  .accent-red { color: var(--red); }
  .cluster-subhead {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.85);
    max-width: 700px;
    margin-bottom: 2rem;
    line-height: 1.5;
  }
  .cluster-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--red), var(--red-dark));
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    font-weight: 700;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(192, 57, 43, 0.4);
  }
  .btn-outline {
    border: 2px solid rgba(255,255,255,0.3);
    background: transparent;
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
  }
  .btn-outline:hover {
    border-color: var(--green);
    background: rgba(39,238,49,0.1);
  }
  .cluster-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--red-soft);
    color: var(--red);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 0.4rem 1.3rem;
    border-radius: 40px;
    margin-bottom: 1rem;
  }
  .section-header h2 {
    font-size: 2rem;
    font-weight: 800;
    color: var(--charcoal);
  }
  .section-divider {
    width: 70px;
    height: 4px;
    background: linear-gradient(90deg, var(--red), var(--green));
    margin: 1rem auto 0;
    border-radius: 2px;
  }
  .cluster-approach {
    padding: 4rem 0;
    background: white;
  }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .step-card {
    background: var(--gray-sf);
    padding: 1.5rem;
    border-radius: 20px;
    position: relative;
    transition: all 0.3s ease;
    border: 1px solid var(--border);
  }
  .step-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
    border-color: var(--red);
  }
  .step-number {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 2rem;
    font-weight: 900;
    color: var(--red);
    opacity: 0.2;
  }
  .step-icon {
    font-size: 2rem;
    color: var(--green);
    margin-bottom: 1rem;
  }
  .step-card h3 {
    font-size: 1.1rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    color: var(--charcoal);
  }
  .step-card p {
    font-size: 0.85rem;
    color: var(--gray-md);
    line-height: 1.6;
    margin: 0;
  }
  .cluster-session {
    padding: 4rem 0;
    background: var(--gray-sf);
  }
  .session-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .session-card {
    background: white;
    padding: 1.5rem;
    border-radius: 20px;
    text-align: center;
    transition: all 0.3s ease;
    border: 1px solid var(--border);
  }
  .session-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
    border-color: var(--green);
  }
  .session-card i {
    font-size: 2rem;
    color: var(--green);
    margin-bottom: 1rem;
  }
  .session-card h3 {
    font-size: 1rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    color: var(--charcoal);
  }
  .session-card p {
    font-size: 0.8rem;
    color: var(--gray-md);
    line-height: 1.5;
    margin: 0;
  }
  .cluster-modules {
    padding: 4rem 0;
    background: white;
  }
  .modules-flex {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .module-block {
    background: var(--gray-sf);
    padding: 2rem;
    border-radius: 20px;
    text-align: center;
    transition: all 0.3s ease;
  }
  .module-block:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }
  .module-block i {
    font-size: 2.5rem;
    color: var(--red);
    margin-bottom: 1rem;
  }
  .module-block h3 {
    font-size: 1.1rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    color: var(--charcoal);
  }
  .module-block p {
    font-size: 0.85rem;
    color: var(--gray-md);
    line-height: 1.6;
    margin: 0;
  }
  .cluster-evaluation {
    padding: 4rem 0;
    background: var(--gray-sf);
    text-align: center;
  }
  .evaluation-content {
    max-width: 700px;
    margin: 0 auto;
    background: white;
    padding: 2rem;
    border-radius: 24px;
    border: 1px solid var(--border);
  }
  .evaluation-content i {
    font-size: 2.5rem;
    color: var(--green);
    margin-bottom: 1rem;
  }
  .evaluation-content h3 {
    font-size: 1.3rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    color: var(--charcoal);
  }
  .evaluation-content p {
    font-size: 0.95rem;
    color: var(--gray-md);
    line-height: 1.6;
  }
  .evaluation-cta {
    text-align: center;
    margin-top: 2rem;
  }
  .cluster-related {
    padding: 3rem 0 5rem;
    background: var(--gray-sf);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .related-card {
    background: white;
    padding: 1.5rem;
    border-radius: 20px;
    text-align: center;
    border: 1px solid var(--border);
  }
  .related-card i {
    font-size: 2rem;
    color: var(--green);
    margin-bottom: 0.75rem;
  }
  .related-card h3 {
    font-size: 1rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: var(--charcoal);
  }
  .related-card p {
    font-size: 0.8rem;
    color: var(--gray-md);
    margin-bottom: 1rem;
  }
  .related-card a {
    color: var(--red);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.85rem;
  }
  .related-card a:hover {
    text-decoration: underline;
  }
  @media (max-width: 900px) {
    .steps-grid { grid-template-columns: 1fr; }
    .session-grid { grid-template-columns: repeat(2, 1fr); }
    .modules-flex { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .session-grid { grid-template-columns: 1fr; }
    .cluster-hero h1 { font-size: 2rem; }
    .section-header h2 { font-size: 1.5rem; }
    .related-grid { grid-template-columns: 1fr; }
  }
</style>