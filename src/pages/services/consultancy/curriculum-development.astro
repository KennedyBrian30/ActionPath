---
// /services/consultancy/curriculum-development.astro
import Layout from "../../../layouts/Layout.astro";

const pageTitle = "Curriculum Development Services | ActionPath Africa";
const pageDescription = "We are the best curriculum development specialists in the region. We create, design, and develop training content and curriculum materials in partnership with NGOs, CBOs, and businesses.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main>
    <!-- Hero Section -->
    <section class="cluster-hero">
      <div class="cluster-hero-inner">
        <div class="cluster-breadcrumb">
          <a href="/">Home</a> <i class="fas fa-chevron-right"></i>
          <a href="/services/consultancy">Consultancy</a> <i class="fas fa-chevron-right"></i>
          <span>Curriculum Development</span>
        </div>
        <div class="cluster-icon-large">
          <i class="fas fa-book-open"></i>
        </div>
        <h1 class="all-red">Curriculum Development</h1>
        <p class="cluster-subhead">We are the best curriculum development specialists in the region. We create, design, and develop training content and curriculum materials. We work in partnership with NGOs, CBOs, and businesses to ensure that the curriculum aligns with the goals and objectives of the organization and meets the needs of the target audience.</p>
        <div class="cluster-ctas">
          <a href="/contact" class="btn-primary"><i class="fas fa-envelope"></i> Inquire About Curriculum Development</a>
          <a href="/services/consultancy" class="btn-outline"><i class="fas fa-arrow-left"></i> All Consultancy Services</a>
        </div>
      </div>
    </section>

    <!-- Expertise Section -->
    <section class="cluster-expertise">
      <div class="cluster-container">
        <div class="expertise-content">
          <div class="section-header">
            <div class="section-eyebrow"><i class="fas fa-star"></i> Our Expertise</div>
            <h2>Why Choose <span class="accent-red">Us</span></h2>
            <div class="section-divider"></div>
          </div>
          <p>We have a deep understanding of the subject matter and the latest trends in education, as well as an understanding of the target audience and the specific needs of the organization. We also work closely with other departments and stakeholders to ensure that the curriculum is aligned with your organization's mission and values. In addition to our curriculum development responsibilities, we also play a key role in professional development and training. We provide guidance and support to your training staff to help them effectively implement the curriculum and achieve the desired learning outcomes.</p>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section class="cluster-services">
      <div class="cluster-container">
        <div class="section-header">
          <div class="section-eyebrow"><i class="fas fa-cogs"></i> What We Do</div>
          <h2>Our Curriculum <span class="accent-red">Services</span></h2>
          <div class="section-divider"></div>
        </div>

        <div class="services-grid">
          <div class="service-card">
            <i class="fas fa-clipboard-list"></i>
            <h3>Training Needs Assessment</h3>
            <p>Conduct a thorough training needs assessment before designing a curriculum.</p>
          </div>
          <div class="service-card">
            <i class="fas fa-file-alt"></i>
            <h3>Curriculum & Materials Development</h3>
            <p>Develop curriculum and training materials that respond to individual and general needs with detailed modules and training materials.</p>
          </div>
          <div class="service-card">
            <i class="fas fa-pen-fancy"></i>
            <h3>Self-Learning Instruments</h3>
            <p>Develop instruments for self-learning within the curriculum: reflective practice exercises, self-assessments, and peer review assessments.</p>
          </div>
          <div class="service-card">
            <i class="fas fa-laptop"></i>
            <h3>Delivery Recommendations</h3>
            <p>Make recommendations about how best to deliver the curricula, including the most effective training strategies and methodologies for in-person, online, or blended learning formats.</p>
          </div>
          <div class="service-card">
            <i class="fas fa-search"></i>
            <h3>Best Practices Review</h3>
            <p>Review, analyze, and incorporate best practices, lessons, and modules learned.</p>
          </div>
          <div class="service-card">
            <i class="fas fa-chalkboard-user"></i>
            <h3>Training of Trainers (TOT)</h3>
            <p>Conduct training of trainers (TOT) on the curricula and curriculum validation with select stakeholders.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Training Guides Section -->
    <section class="cluster-guides">
      <div class="cluster-container">
        <div class="section-header">
          <div class="section-eyebrow"><i class="fas fa-book"></i> Our Portfolio</div>
          <h2>Training Guides <span class="accent-red">We've Designed</span></h2>
          <div class="section-divider"></div>
          <p class="section-subtitle">Some of the training guides that we have designed and written for NGOs include the following:</p>
        </div>

        <div class="guides-grid">
          <div class="guide-item">Entrepreneurship Skills Training Guide</div>
          <div class="guide-item">Psychosocial Support & Trauma Healing Training Guide</div>
          <div class="guide-item">Waste Management Training Guide</div>
          <div class="guide-item">Sexual and Reproductive Health Training Guide</div>
          <div class="guide-item">Life Skills & Psychoeducation Training Guide</div>
          <div class="guide-item">Child Rights & Agroecology Best Practices Training Guide</div>
          <div class="guide-item">Sexual & Reproductive Health Education Training Guide</div>
          <div class="guide-item">Human Rights-Based Approach to Development Training Guide</div>
        </div>

        <div class="guides-cta">
          <a href="/contact" class="btn-primary"><i class="fas fa-calendar-alt"></i> Request a Curriculum Development Consultation</a>
        </div>
      </div>
    </section>

    <!-- Related Services -->
    <section class="cluster-related">
      <div class="cluster-container">
        <div class="related-grid">
          <div class="related-card">
            <i class="fas fa-chart-line"></i>
            <h3>MEARL Services</h3>
            <p>Evaluate the effectiveness of your curriculum.</p>
            <a href="/services/consultancy/monitoring-evaluation">Learn more →</a>
          </div>
          <div class="related-card">
            <i class="fas fa-heart"></i>
            <h3>Counseling Services</h3>
            <p>Integrate psychosocial content into your curriculum.</p>
            <a href="/services/consultancy/psychosocial-support">Learn more →</a>
          </div>
          <div class="related-card">
            <i class="fas fa-chalkboard-user"></i>
            <h3>Training of Trainers (TOT)</h3>
            <p>Train facilitators to deliver your new curriculum.</p>
            <a href="/services/training/tot">Learn more →</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  .cluster-hero {
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    padding: 4rem 0;
    color: white;
  }
  .cluster-hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .cluster-breadcrumb {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.6);
    margin-bottom: 2rem;
  }
  .cluster-breadcrumb a {
    color: var(--green-lt);
    text-decoration: none;
  }
  .cluster-breadcrumb i {
    font-size: 0.7rem;
    margin: 0 0.5rem;
  }
  .cluster-icon-large {
    font-size: 4rem;
    color: var(--green);
    margin-bottom: 1rem;
  }
  .cluster-hero h1 {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .all-red {
    color: var(--red);
  }
  .accent-red { color: var(--red); }
  .cluster-subhead {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.85);
    max-width: 900px;
    margin-bottom: 2rem;
    line-height: 1.5;
  }
  .cluster-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--red), var(--red-dark));
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    font-weight: 700;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(192, 57, 43, 0.4);
  }
  .btn-outline {
    border: 2px solid rgba(255,255,255,0.3);
    background: transparent;
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
  }
  .btn-outline:hover {
    border-color: var(--green);
    background: rgba(39,238,49,0.1);
  }
  .cluster-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--red-soft);
    color: var(--red);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 0.4rem 1.3rem;
    border-radius: 40px;
    margin-bottom: 1rem;
  }
  .section-header h2 {
    font-size: 2rem;
    font-weight: 800;
    color: var(--charcoal);
  }
  .section-divider {
    width: 70px;
    height: 4px;
    background: linear-gradient(90deg, var(--red), var(--green));
    margin: 1rem auto 0;
    border-radius: 2px;
  }
  .section-subtitle {
    color: var(--gray-md);
    font-size: 1rem;
    max-width: 680px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .cluster-expertise {
    padding: 4rem 0;
    background: white;
  }
  .expertise-content p {
    color: var(--gray-md);
    line-height: 1.7;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }
  .cluster-services {
    padding: 4rem 0;
    background: var(--gray-sf);
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .service-card {
    background: white;
    padding: 1.5rem;
    border-radius: 20px;
    text-align: center;
    transition: all 0.3s ease;
    border: 1px solid var(--border);
  }
  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
    border-color: var(--green);
  }
  .service-card i {
    font-size: 2rem;
    color: var(--green);
    margin-bottom: 1rem;
  }
  .service-card h3 {
    font-size: 1rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    color: var(--charcoal);
  }
  .service-card p {
    font-size: 0.8rem;
    color: var(--gray-md);
    line-height: 1.5;
    margin: 0;
  }
  .cluster-guides {
    padding: 4rem 0;
    background: white;
  }
  .guides-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 800px;
    margin: 0 auto 2rem;
  }
  .guide-item {
    background: var(--gray-sf);
    padding: 1rem 1.25rem;
    border-radius: 12px;
    font-weight: 500;
    color: var(--charcoal);
    border-left: 3px solid var(--red);
    transition: all 0.3s ease;
  }
  .guide-item:hover {
    transform: translateX(5px);
    background: var(--red-soft);
  }
  .guides-cta {
    text-align: center;
    margin-top: 1rem;
  }
  .cluster-related {
    padding: 3rem 0 5rem;
    background: var(--gray-sf);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .related-card {
    background: white;
    padding: 1.5rem;
    border-radius: 20px;
    text-align: center;
    border: 1px solid var(--border);
  }
  .related-card i {
    font-size: 2rem;
    color: var(--green);
    margin-bottom: 0.75rem;
  }
  .related-card h3 {
    font-size: 1rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: var(--charcoal);
  }
  .related-card p {
    font-size: 0.8rem;
    color: var(--gray-md);
    margin-bottom: 1rem;
  }
  .related-card a {
    color: var(--red);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.85rem;
  }
  .related-card a:hover {
    text-decoration: underline;
  }
  @media (max-width: 900px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .services-grid { grid-template-columns: 1fr; }
    .guides-grid { grid-template-columns: 1fr; }
    .related-grid { grid-template-columns: 1fr; }
    .cluster-hero h1 { font-size: 2rem; }
    .section-header h2 { font-size: 1.5rem; }
  }
</style>