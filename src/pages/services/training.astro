---
// services/training.astro - Training Areas Page
import Layout from "../../layouts/Layout.astro";

// Complete Training Areas with descriptions and images
const trainingCategories = {
  entrepreneurship: {
    title: "Entrepreneurship & Climate Resilient Practices",
    description: "Empowering individuals and communities with business acumen, entrepreneurial mindset, and climate-smart techniques for sustainable livelihoods in a changing environment.",
    icon: "fas fa-seedling",
    color: "#27ee31",
    image: "/agriculture-climate.webp",
    items: [
      { name: "Design Drive Entrepreneurship", description: "Human-centered design thinking for business innovation and problem-solving." },
      { name: "Youth employability skills & how to start a business", description: "Practical skills for young people to enter the workforce or launch ventures." },
      { name: "Climate Smart Agriculture", description: "Resilient farming techniques, drought-resistant crops, and sustainable practices." },
      { name: "Financial management", description: "Budgeting, bookkeeping, and financial planning for individuals and enterprises." },
      { name: "Project planning & Management", description: "End-to-end project lifecycle management from design to evaluation." },
      { name: "Risk Analysis & Sustainability", description: "Identifying, assessing, and mitigating risks while ensuring long-term viability." }
    ]
  },
  lifeSkills: {
    title: "Life Skills & Employability",
    description: "Building foundational soft skills, professional development, and workplace readiness that enable individuals to thrive in any professional environment.",
    icon: "fas fa-users",
    color: "#c0392b",
    image: "/vocational-skills.webp",
    items: [
      { name: "Life skills", description: "Critical thinking, decision-making, problem-solving, and self-awareness." },
      { name: "Team Building", description: "Collaboration, trust-building, and effective group dynamics." },
      { name: "Facilitation Skills", description: "Leading meetings, workshops, and group learning experiences effectively." },
      { name: "Facilitation Skills & ToT", description: "Advanced facilitation plus train-the-trainer methodology." },
      { name: "Organisational Documentation", description: "Record keeping, reporting, and organizational memory systems." },
      { name: "Effective Communication", description: "Verbal, written, and non-verbal communication for professional settings." },
      { name: "Effective Customer Service", description: "Client care, complaint handling, and service excellence." },
      { name: "Negotiation and Conflict Management", description: "Resolving disputes and reaching win-win agreements." },
      { name: "Report Writing", description: "Structured, clear, and impactful report creation for various audiences." }
    ]
  },
  empowerment: {
    title: "Youth & Women Empowerment",
    description: "Focused programs addressing unique barriers faced by young people and women, fostering leadership, economic independence, and social inclusion.",
    icon: "fas fa-female",
    color: "#e67e22",
    image: "/women-youth.webp",
    items: [
      { name: "How to establish a CBO", description: "Step-by-step guide to registering and managing community-based organizations." },
      { name: "Gender & Social Inclusion", description: "Mainstreaming gender equality and including marginalized groups." },
      { name: "Human Based Approach to Development (HRBA)", description: "Rights-based programming that puts people at the center." },
      { name: "Grants & Proposal Writing", description: "Crafting compelling proposals and securing funding for development projects." }
    ]
  }
};

// Key features of our training approach
const trainingFeatures = [
  { icon: "fas fa-certificate", title: "Competency-Based", description: "Training focused on measurable skills and practical application." },
  { icon: "fas fa-users", title: "Participatory", description: "Learner-centered methodologies that respect local knowledge." },
  { icon: "fas fa-chart-line", title: "Market-Driven", description: "Skills aligned to current market demands and opportunities." },
  { icon: "fas fa-globe-africa", title: "Contextualized", description: "Adapted to local languages, cultures, and economic realities." },
  { icon: "fas fa-handshake", title: "Partnership-Based", description: "Collaborative delivery with local organizations and stakeholders." },
  { icon: "fas fa-chart-simple", title: "Impact-Focused", description: "Clear indicators and measurement of learning outcomes." }
];

// Sample training images gallery
const galleryImages = [
  "/hero-community-1.webp",
  "/hero-livelihood-2.webp",
  "/hero-training-3.webp",
  "/hero-empowerment-4.webp",
  "/hero-resilience-5.webp",
  "/welcome-community.webp"
];
---

<Layout title="ActionPath Africa | Training Areas - Comprehensive Capacity Building Programs" description="Explore ActionPath Africa's comprehensive training programs in entrepreneurship, climate resilience, life skills, employability, youth and women empowerment across Africa.">

  <!-- Hero Section -->
  <section class="training-hero full-width">
    <div class="training-hero-overlay"></div>
    <div class="training-hero-content">
      <div class="training-hero-badge"><i class="fas fa-chalkboard-user"></i> Training Programs</div>
      <h1 class="training-hero-title">Transformative <span class="highlight">Training Areas</span></h1>
      <p class="training-hero-desc">ActionPath Africa delivers competency-based, participatory training programs designed to equip individuals and organizations with practical skills for sustainable development.</p>
      <div class="training-hero-buttons">
        <a href="#categories" class="btn-primary"><i class="fas fa-arrow-down"></i> Explore Categories</a>
        <a href="/contact" class="btn-outline"><i class="fas fa-calendar-alt"></i> Request Training</a>
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section id="categories" class="categories-section full-width">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-eyebrow"><i class="fas fa-layer-group"></i> Our Programs</div>
        <h2>Training <span class="accent-red">Categories</span></h2>
        <div class="section-divider"></div>
        <p class="section-subtitle">Comprehensive, competency-based programs organized into three strategic pillars</p>
      </div>

      <div class="categories-grid">
        <!-- Entrepreneurship Category -->
        <div class="category-card" data-category="entrepreneurship">
          <div class="category-card-image">
            <img src={trainingCategories.entrepreneurship.image} alt={trainingCategories.entrepreneurship.title} loading="lazy" />
            <div class="category-card-icon" style={`background: ${trainingCategories.entrepreneurship.color}20; color: ${trainingCategories.entrepreneurship.color}`}>
              <i class={trainingCategories.entrepreneurship.icon}></i>
            </div>
          </div>
          <div class="category-card-content">
            <h3 class="category-card-title">{trainingCategories.entrepreneurship.title}</h3>
            <p class="category-card-desc">{trainingCategories.entrepreneurship.description}</p>
            <div class="category-items-list">
              {trainingCategories.entrepreneurship.items.map(item => (
                <div class="category-item-detail" key={item.name}>
                  <div class="item-header">
                    <i class="fas fa-check-circle" style={`color: ${trainingCategories.entrepreneurship.color}`}></i>
                    <strong>{item.name}</strong>
                  </div>
                  <p class="item-description">{item.description}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Life Skills Category -->
        <div class="category-card" data-category="lifeskills">
          <div class="category-card-image">
            <img src={trainingCategories.lifeSkills.image} alt={trainingCategories.lifeSkills.title} loading="lazy" />
            <div class="category-card-icon" style={`background: ${trainingCategories.lifeSkills.color}20; color: ${trainingCategories.lifeSkills.color}`}>
              <i class={trainingCategories.lifeSkills.icon}></i>
            </div>
          </div>
          <div class="category-card-content">
            <h3 class="category-card-title">{trainingCategories.lifeSkills.title}</h3>
            <p class="category-card-desc">{trainingCategories.lifeSkills.description}</p>
            <div class="category-items-list">
              {trainingCategories.lifeSkills.items.map(item => (
                <div class="category-item-detail" key={item.name}>
                  <div class="item-header">
                    <i class="fas fa-check-circle" style={`color: ${trainingCategories.lifeSkills.color}`}></i>
                    <strong>{item.name}</strong>
                  </div>
                  <p class="item-description">{item.description}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Youth & Women Empowerment Category -->
        <div class="category-card" data-category="empowerment">
          <div class="category-card-image">
            <img src={trainingCategories.empowerment.image} alt={trainingCategories.empowerment.title} loading="lazy" />
            <div class="category-card-icon" style={`background: ${trainingCategories.empowerment.color}20; color: ${trainingCategories.empowerment.color}`}>
              <i class={trainingCategories.empowerment.icon}></i>
            </div>
          </div>
          <div class="category-card-content">
            <h3 class="category-card-title">{trainingCategories.empowerment.title}</h3>
            <p class="category-card-desc">{trainingCategories.empowerment.description}</p>
            <div class="category-items-list">
              {trainingCategories.empowerment.items.map(item => (
                <div class="category-item-detail" key={item.name}>
                  <div class="item-header">
                    <i class="fas fa-check-circle" style={`color: ${trainingCategories.empowerment.color}`}></i>
                    <strong>{item.name}</strong>
                  </div>
                  <p class="item-description">{item.description}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Training Approach Section -->
  <section class="approach-section full-width">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-eyebrow"><i class="fas fa-chalkboard"></i> Our Methodology</div>
        <h2>Our Training <span class="accent-red">Approach</span></h2>
        <div class="section-divider"></div>
        <p class="section-subtitle">Participatory, learner-centered methodologies that create lasting impact</p>
      </div>
      <div class="features-grid">
        {trainingFeatures.map(feature => (
          <div class="feature-card" key={feature.title}>
            <div class="feature-icon"><i class={feature.icon}></i></div>
            <h3 class="feature-title">{feature.title}</h3>
            <p class="feature-desc">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Delivery Formats Section -->
  <section class="formats-section full-width">
    <div class="section-inner">
      <div class="formats-grid">
        <div class="formats-text">
          <div class="section-eyebrow"><i class="fas fa-clock"></i> Flexible Delivery</div>
          <h2>Training <span class="accent-red">Formats</span></h2>
          <div class="section-divider left"></div>
          <p>We offer flexible training delivery options to meet the diverse needs of our clients and participants.</p>
          <div class="formats-list">
            <div class="format-item"><i class="fas fa-chalkboard-user"></i> <strong>In-Person Workshops</strong> – Immersive, hands-on training at community or partner locations</div>
            <div class="format-item"><i class="fas fa-laptop"></i> <strong>Virtual Training</strong> – Live, interactive online sessions with expert facilitators</div>
            <div class="format-item"><i class="fas fa-users"></i> <strong>Train-the-Trainer</strong> – Building local capacity for sustainable knowledge transfer</div>
            <div class="format-item"><i class="fas fa-mobile-alt"></i> <strong>Blended Learning</strong> – Combined digital and in-person for maximum flexibility</div>
            <div class="format-item"><i class="fas fa-building"></i> <strong>Custom In-House</strong> – Tailored programs for organizational teams</div>
          </div>
        </div>
        <div class="formats-image">
          <img src="/hero-training-3.webp" alt="Training session" loading="lazy" />
          <div class="formats-stats">
            <div class="format-stat"><span class="format-stat-number">95%</span><span class="format-stat-label">Participant Satisfaction</span></div>
            <div class="format-stat"><span class="format-stat-number">87%</span><span class="format-stat-label">Skills Applied</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Section -->
  <section class="gallery-section full-width">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-eyebrow"><i class="fas fa-images"></i> In Action</div>
        <h2>Training <span class="accent-red">Gallery</span></h2>
        <div class="section-divider"></div>
        <p class="section-subtitle">Moments from our training programs across Africa</p>
      </div>
      <div class="gallery-grid">
        {galleryImages.map((img, idx) => (
          <div class="gallery-item" key={idx}>
            <img src={img} alt={`Training session ${idx + 1}`} loading="lazy" />
            <div class="gallery-overlay">
              <i class="fas fa-search-plus"></i>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="training-cta-section full-width">
    <div class="cta-container">
      <div class="cta-content">
        <div class="cta-eyebrow">Ready to Build Capacity?</div>
        <h2>Let's Design a <span class="cta-highlight">Training Program</span> For Your Team or Community</h2>
        <p>Contact us to discuss your training needs, request a catalog, or schedule a consultation.</p>
        <div class="cta-buttons">
          <a href="/contact" class="btn-primary btn-large"><i class="fas fa-envelope"></i> Contact Our Team</a>
          <a href="/services/training-catalog" class="btn-outline-light btn-large"><i class="fas fa-download"></i> Download Catalog</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style is:global>
  :root {
    --red: #c0392b;
    --red-dark: #a93226;
    --red-soft: rgba(192, 57, 43, 0.1);
    --green: #27ee31;
    --green-lt: #27f731;
    --charcoal: #1e293b;
    --gray-dk: #334155;
    --gray-md: #5a6e8a;
    --gray-sf: #f5f7fa;
    --border: #e2e8f0;
    --white: #ffffff;
    --shadow-sm: 0 4px 12px rgba(0, 0, 0, 0.05);
    --shadow-md: 0 8px 24px rgba(0, 0, 0, 0.08);
    --shadow-lg: 0 20px 35px rgba(0, 0, 0, 0.12);
    --shadow-xl: 0 30px 50px rgba(0, 0, 0, 0.15);
  }

  .full-width { width: 100%; margin: 0; padding: 0; }
  .section-inner { max-width: 1400px; margin: 0 auto; padding: 0 2rem; }

  /* Hero Section */
  .training-hero {
    position: relative;
    min-height: 70vh;
    background: linear-gradient(135deg, var(--charcoal) 0%, #0f172a 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }
  .training-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url('/hero-training-3.webp');
    background-size: cover;
    background-position: center;
    opacity: 0.12;
    filter: blur(2px);
  }
  .training-hero-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(30,41,59,0.4) 0%, var(--charcoal) 100%);
  }
  .training-hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    padding: 2rem;
    animation: fadeInUp 0.8s ease forwards;
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .training-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(39, 238, 49, 0.15);
    color: var(--green);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.35rem 1.2rem;
    border-radius: 40px;
    margin-bottom: 1.5rem;
  }
  .training-hero-title {
    font-family: "Outfit", sans-serif;
    font-size: 3.8rem;
    font-weight: 900;
    line-height: 1.2;
    color: white;
    margin-bottom: 1.5rem;
  }
  .training-hero-title .highlight {
    color: var(--green);
  }
  .training-hero-desc {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.85);
    max-width: 650px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }
  .training-hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Categories Section */
  .categories-section {
    padding: 5rem 0;
    background: linear-gradient(135deg, #fff 0%, var(--gray-sf) 100%);
  }
  .categories-grid {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    margin-top: 2rem;
  }
  .category-card {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    background: var(--white);
    border-radius: 32px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    opacity: 0;
    transform: translateX(-30px);
    animation: slideInLeft 0.6s ease forwards;
  }
  .category-card:nth-child(2) { animation-delay: 0.15s; }
  .category-card:nth-child(3) { animation-delay: 0.3s; }
  @keyframes slideInLeft { to { opacity: 1; transform: translateX(0); } }
  .category-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
    border-color: var(--green);
  }
  .category-card-image {
    position: relative;
    overflow: hidden;
  }
  .category-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1);
  }
  .category-card:hover .category-card-image img {
    transform: scale(1.05);
  }
  .category-card-icon {
    position: absolute;
    bottom: 20px;
    left: 20px;
    width: 56px;
    height: 56px;
    background: rgba(0,0,0,0.6);
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    backdrop-filter: blur(4px);
  }
  .category-card-content {
    padding: 2rem;
  }
  .category-card-title {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: 0.75rem;
  }
  .category-card-desc {
    color: var(--gray-md);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  .category-items-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .category-item-detail {
    padding: 0.5rem;
    border-radius: 12px;
    transition: all 0.2s ease;
  }
  .category-item-detail:hover {
    background: var(--gray-sf);
    transform: translateX(5px);
  }
  .item-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 0.25rem;
  }
  .item-header i {
    font-size: 0.85rem;
  }
  .item-header strong {
    font-size: 0.9rem;
    color: var(--charcoal);
  }
  .item-description {
    font-size: 0.8rem;
    color: var(--gray-md);
    margin-left: 1.6rem;
    line-height: 1.5;
  }

  /* Approach Section */
  .approach-section {
    padding: 5rem 0;
    background: var(--white);
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }
  .feature-card {
    text-align: center;
    padding: 2rem;
    background: var(--gray-sf);
    border-radius: 24px;
    border: 1px solid var(--border);
    transition: all 0.3s ease;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.5s ease forwards;
  }
  .feature-card:nth-child(1) { animation-delay: 0.05s; }
  .feature-card:nth-child(2) { animation-delay: 0.1s; }
  .feature-card:nth-child(3) { animation-delay: 0.15s; }
  .feature-card:nth-child(4) { animation-delay: 0.2s; }
  .feature-card:nth-child(5) { animation-delay: 0.25s; }
  .feature-card:nth-child(6) { animation-delay: 0.3s; }
  @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }
  .feature-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: var(--red);
  }
  .feature-icon {
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, var(--red), var(--red-dark));
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    color: white;
    font-size: 1.5rem;
    transition: transform 0.3s ease;
  }
  .feature-card:hover .feature-icon {
    transform: scale(1.1) rotate(5deg);
  }
  .feature-title {
    font-size: 1rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }
  .feature-desc {
    font-size: 0.8rem;
    color: var(--gray-md);
    line-height: 1.5;
  }

  /* Formats Section */
  .formats-section {
    padding: 5rem 0;
    background: linear-gradient(135deg, var(--gray-sf) 0%, #fff 100%);
  }
  .formats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .formats-text h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .formats-text p {
    color: var(--gray-md);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  .formats-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .format-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0.75rem;
    background: var(--white);
    border-radius: 12px;
    border: 1px solid var(--border);
    transition: all 0.2s ease;
  }
  .format-item:hover {
    transform: translateX(5px);
    border-color: var(--green);
  }
  .format-item i {
    width: 32px;
    color: var(--green);
    font-size: 1.1rem;
  }
  .formats-image {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .formats-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .formats-stats {
    position: absolute;
    bottom: 20px;
    left: 20px;
    right: 20px;
    display: flex;
    gap: 1rem;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(10px);
    padding: 1rem;
    border-radius: 16px;
    justify-content: space-around;
  }
  .format-stat {
    text-align: center;
  }
  .format-stat-number {
    display: block;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--green);
  }
  .format-stat-label {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.8);
  }

  /* Gallery Section */
  .gallery-section {
    padding: 5rem 0;
    background: var(--white);
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .gallery-item {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 4/3;
    cursor: pointer;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .gallery-item:hover img {
    transform: scale(1.08);
  }
  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }
  .gallery-overlay i {
    color: white;
    font-size: 2rem;
  }

  /* CTA Section */
