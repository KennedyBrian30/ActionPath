      /* ══════════════════════════════════════════════════
         WHATSAPP FLOAT
      ══════════════════════════════════════════════════ */
      .whatsapp-float {
        position: fixed;
        bottom: 28px;
        right: 28px;
        background: #25D366;
        color: white;
        width: 58px;
        height: 58px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        box-shadow: 0 6px 20px rgba(37, 211, 102, 0.4);
        transition: var(--transition);
        z-index: 700;
        border: 3px solid white;
      }

      .whatsapp-float:hover {
        transform: scale(1.08) translateY(-2px);
        box-shadow: 0 10px 28px rgba(37, 211, 102, 0.5);
        background: #20b858;
      }

      /* Tooltip on hover */
      .whatsapp-float::before {
        content: "Chat with us";
        position: absolute;
        right: calc(100% + 10px);
        background: var(--dark-charcoal);
        color: white;
        font-size: 0.72rem;
        font-weight: 600;
        padding: 0.35rem 0.75rem;
        border-radius: 20px;
        white-space: nowrap;
        opacity: 0;
        transform: translateX(6px);
        transition: opacity 0.2s, transform 0.2s;
        pointer-events: none;
      }

      .whatsapp-float:hover::before {
        opacity: 1;
        transform: translateX(0);
      }

      /* ══════════════════════════════════════════════════
         BACK-TO-TOP
      ══════════════════════════════════════════════════ */
      #back-to-top {
        position: fixed;
        bottom: 28px;
        right: 100px;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--dark-charcoal);
        color: white;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        box-shadow: var(--shadow-md);
        transition: var(--transition);
        opacity: 0;
        transform: translateY(10px);
        pointer-events: none;
        z-index: 700;
      }

      #back-to-top.visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }

      #back-to-top:hover {
        background: var(--primary-red);
        transform: translateY(-2px);
      }

